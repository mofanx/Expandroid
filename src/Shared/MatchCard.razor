@using Expandroid.Services
@using Expandroid.Models
@inject ILocalizationService LocalizationService
@inject Expandroid.Services.IDialogService DialogService

<MudCard Elevation="2" Class="pa-4 mb-3 match-card-hover">
    <MudStack Justify="@Justify.SpaceBetween" Row="true" Align="Align.Center">
        <MudStack Spacing="0" Class="flex-grow-1 me-2" Style="overflow: hidden; min-width: 0;">
            <MudText Color="Color.Primary" Typo="Typo.h6" Align="Align.Start" Style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@Item.Key</MudText>
            <MudText Typo="Typo.body2" Color="Color.Default" Align="Align.Start" Style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@Item.Value.Replace</MudText>
        </MudStack>
        <MudStack Row="true" Spacing="1">
            <MudIconButton OnClick="OnEdit" Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Variant="Variant.Text" Size="Size.Medium" />
            <MudIconButton OnClick="ConfirmDelete" Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Variant="Variant.Text" Size="Size.Medium" />
        </MudStack>
    </MudStack>
    @if (Item.Value.Vars?.Count > 0)
    {
        <MudStack Row="true" Spacing="1" Class="mt-2" Wrap="Wrap.Wrap">
            <MudChip Size="Size.Small" Color="Color.Secondary">
                @Item.Value.Vars.Count @LocalizationService.GetString("VarsLabel")
            </MudChip>
            @foreach (var v in Item.Value.Vars.Take(3))
            {
                <MudChip Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">@v.Type</MudChip>
            }
            @if (Item.Value.Vars.Count > 3)
            {
                <MudChip Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">+@(Item.Value.Vars.Count - 3)</MudChip>
            }
        </MudStack>
    }
</MudCard>

@code {
    [Parameter] public KeyValuePair<string, Match> Item { get; set; }
    [Parameter] public EventCallback OnEdit { get; set; }
    [Parameter] public EventCallback OnDelete { get; set; }

    private async Task ConfirmDelete()
    {
        var confirm = await DialogService.DisplayConfirmAsync(
            LocalizationService.GetString("DeleteMatch"),
            string.Format(LocalizationService.GetString("ConfirmDeleteMatch"), Item.Key),
            LocalizationService.GetString("Delete"),
            LocalizationService.GetString("Cancel"));
        if (confirm)
        {
            await OnDelete.InvokeAsync();
        }
    }
}
