@inject NavigationManager NavigationManager
@inject ILocalizationService LocalizationService
@implements IDisposable

@if (_showNav)
{
    <MudAppBar Elevation="8" Color="Color.Surface" Fixed="true" Bottom="true" Style="padding-bottom: env(safe-area-inset-bottom); height: calc(56px + env(safe-area-inset-bottom));">
        <MudStack Row="true" Justify="@Justify.SpaceAround" Align="@Align.Center" Class="flex-grow-1">
            <MudNavMenu Class="bottom-nav-menu">
                <MudNavLink Icon="@Icons.Material.Filled.ListAlt" Title="@LocalizationService.GetString("Matches")"
                            Href="/" Active="@(_currentRoute == "/")" Class="bottom-nav-item">
                    <MudText Typo="Typo.caption">@LocalizationService.GetString("Matches")</MudText>
                </MudNavLink>
                <MudNavLink Icon="@Icons.Material.Filled.Folder" Title="@LocalizationService.GetString("Files")"
                            Href="/files" Active="@(_currentRoute == "/files")" Class="bottom-nav-item">
                    <MudText Typo="Typo.caption">@LocalizationService.GetString("Files")</MudText>
                </MudNavLink>
                <MudNavLink Icon="@Icons.Material.Filled.Build" Title="@LocalizationService.GetString("Tools")"
                            Href="/tools" Active="@(_currentRoute == "/tools")" Class="bottom-nav-item">
                    <MudText Typo="Typo.caption">@LocalizationService.GetString("Tools")</MudText>
                </MudNavLink>
                <MudNavLink Icon="@Icons.Material.Filled.Settings" Title="@LocalizationService.GetString("Settings")"
                            Href="/settings" Active="@(_currentRoute == "/settings")" Class="bottom-nav-item">
                    <MudText Typo="Typo.caption">@LocalizationService.GetString("Settings")</MudText>
                </MudNavLink>
            </MudNavMenu>
        </MudStack>
    </MudAppBar>
}

<style>
    .bottom-nav-menu {
        display: flex;
        flex-direction: row;
        width: 100%;
        border: none !important;
        background: transparent !important;
    }
    .bottom-nav-menu .mud-nav-link {
        flex: 1;
        flex-direction: column !important;
        align-items: center !important;
        justify-content: center;
        gap: 2px;
        padding: 4px 0;
        min-height: 48px;
        color: var(--mud-palette-text-secondary) !important;
        opacity: 0.7;
        transition: opacity 0.2s ease, color 0.2s ease;
    }
    .bottom-nav-menu .mud-nav-link:hover {
        opacity: 0.9;
    }
    .bottom-nav-menu .mud-nav-link.mud-nav-link-active {
        color: var(--mud-palette-primary) !important;
        opacity: 1;
    }
    .bottom-nav-menu .mud-nav-link.mud-nav-link-active .mud-icon-root {
        color: var(--mud-palette-primary);
    }
    .bottom-nav-menu .mud-nav-link .mud-icon-root {
        font-size: 24px;
        display: block;
        text-align: center;
        margin: 0 !important;
    }
    .bottom-nav-menu .mud-nav-link .mud-typography {
        font-size: 0.7rem;
        line-height: 1;
        text-align: center;
        margin: 0;
    }
</style>

@code {
    private string _currentRoute = "/";
    private bool _showNav = true;

    protected override void OnInitialized()
    {
        UpdateRoute();
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        InvokeAsync(() =>
        {
            UpdateRoute();
            StateHasChanged();
        });
    }

    private void UpdateRoute()
    {
        var path = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        if (string.IsNullOrEmpty(path) || path == "/")
        {
            _currentRoute = "/";
            _showNav = true;
        }
        else if (path.StartsWith("files"))
        {
            _currentRoute = "/files";
            _showNav = true;
        }
        else if (path.StartsWith("tools"))
        {
            _currentRoute = "/tools";
            _showNav = true;
        }
        else if (path.StartsWith("permission"))
        {
            _currentRoute = path;
            _showNav = false;
        }
        else if (path.StartsWith("settings"))
        {
            _currentRoute = "/settings";
            _showNav = true;
        }
        else if (path.StartsWith("globalvars"))
        {
            _currentRoute = "/globalvars";
            _showNav = true;
        }
        else
        {
            _currentRoute = path;
            _showNav = true;
        }
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
