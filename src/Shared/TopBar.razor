@inject NavigationManager NavigationManager
@inject ILocalizationService LocalizationService
@using Microsoft.AspNetCore.Components.Routing

<MudAppBar Elevation="2" Color="Color.Primary" Fixed="true" Style="padding-top: env(safe-area-inset-top); height: calc(64px + env(safe-area-inset-top));">
    @if (_showBack)
    {
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Color="Color.Inherit" OnClick="GoBack" Class="mr-2" />
    }
    <MudText Typo="Typo.h6" Class="flex-grow-1">
        @_pageTitle
    </MudText>

    <MudIconButton Icon="@Icons.Material.Filled.Settings" Color="Color.Inherit" OnClick="GoSettings" />
</MudAppBar>

@implements IDisposable

@code {
    private string _pageTitle = "EspansoGo";
    private bool _showBack = false;

    protected override void OnInitialized()
    {
        UpdateRouteInfo();
        LocalizationService.OnLanguageChanged += OnLanguageChanged;
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLanguageChanged()
    {
        InvokeAsync(() =>
        {
            UpdateRouteInfo();
            StateHasChanged();
        });
    }

    private void OnLocationChanged(object sender, LocationChangedEventArgs e)
    {
        InvokeAsync(() =>
        {
            UpdateRouteInfo();
            StateHasChanged();
        });
    }

    private void UpdateRouteInfo()
    {
        var path = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);

        if (string.IsNullOrEmpty(path) || path == "/")
        {
            _pageTitle = "EspansoGo";
            _showBack = false;
        }
        else if (path.StartsWith("tools"))
        {
            _pageTitle = LocalizationService.GetString("ToolsTitle");
            _showBack = true;
        }
        else if (path.StartsWith("permission"))
        {
            _pageTitle = LocalizationService.GetString("PermissionCheck");
            _showBack = false;
        }
        else if (path.StartsWith("syncsetup"))
        {
            _pageTitle = LocalizationService.GetString("SetupWizardTitle");
            _showBack = true;
        }
        else if (path.StartsWith("syncsettings"))
        {
            _pageTitle = LocalizationService.GetString("SyncSettings");
            _showBack = true;
        }
        else if (path.StartsWith("packages"))
        {
            _pageTitle = LocalizationService.GetString("PackageStore");
            _showBack = true;
        }
        else if (path.StartsWith("globalvars"))
        {
            _pageTitle = LocalizationService.GetString("GlobalVariables");
            _showBack = true;
        }
        else if (path.StartsWith("files/"))
        {
            var fileName = path.Substring("files/".Length);
            _pageTitle = fileName == "__uncategorized__" ? LocalizationService.GetString("Uncategorized") : Uri.UnescapeDataString(fileName);
            _showBack = true;
        }
        else if (path.StartsWith("files"))
        {
            _pageTitle = LocalizationService.GetString("Files");
            _showBack = false;
        }
        else if (path.StartsWith("conflicts"))
        {
            _pageTitle = LocalizationService.GetString("ConflictResolution");
            _showBack = true;
        }
        else if (path.StartsWith("settings"))
        {
            _pageTitle = LocalizationService.GetString("Settings");
            _showBack = true;
        }
        else
        {
            _pageTitle = "EspansoGo";
            _showBack = false;
        }
    }

    private void GoBack()
    {
        var path = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        if (path.StartsWith("conflicts"))
            NavigationManager.NavigateTo("/syncsettings");
        else if (path.StartsWith("files/"))
            NavigationManager.NavigateTo("/files");
        else if (path.StartsWith("syncsetup"))
            NavigationManager.NavigateTo("/syncsettings");
        else if (path.StartsWith("syncsettings") || path.StartsWith("globalvars") || path.StartsWith("packages"))
            NavigationManager.NavigateTo("/settings");
        else
            NavigationManager.NavigateTo("/");
    }
    private void GoSettings() => NavigationManager.NavigateTo("/settings");

    public void Dispose()
    {
        LocalizationService.OnLanguageChanged -= OnLanguageChanged;
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
