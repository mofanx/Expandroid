@inherits LayoutComponentBase
@inject IThemeService ThemeService
@implements IDisposable

<MudThemeProvider IsDarkMode="@ThemeService.IsDarkMode" Theme="MudAppTheme"/>
<MudDialogProvider/>
<MudSnackbarProvider/>

<MudLayout>
    <TopBar />
    <MudMainContent Style="padding-top: calc(96px + env(safe-area-inset-top)); padding-bottom: calc(72px + env(safe-area-inset-bottom));">
        <MudContainer MaxWidth="MaxWidth.Medium" Class="pa-4 app-content">
            <div class="page-enter">
                @Body
            </div>
        </MudContainer>
    </MudMainContent>
    <BottomNav />
</MudLayout>

@code {
#pragma warning disable CS0618
    private MudTheme MudAppTheme = new()
    {
        Palette = new Palette()
        {
            Primary = "#6366f1",
            Secondary = "#8b5cf6",
            Success = "#10b981",
            Error = "#f43f5e",
            Background = "#f8fafc",
            Surface = "#ffffff",
            AppbarBackground = "#6366f1",
            AppbarText = "#ffffff",
            TextPrimary = "#1e293b",
            TextSecondary = "#475569",
            TextDisabled = "#94a3b8",
            Divider = "#e2e8f0",
            DividerLight = "#f1f5f9",
            ActionDefault = "#475569",
            ActionDisabled = "#94a3b8",
            LinesDefault = "#cbd5e1",
            LinesInputs = "#cbd5e1",
            TableLines = "#e2e8f0",
            TableHover = "#f1f5f9",
        },
        PaletteDark = new Palette()
        {
            Primary = "#818cf8",
            Secondary = "#a78bfa",
            Success = "#34d399",
            Error = "#fb7185",
            Background = "#0f172a",
            Surface = "#1e293b",
            AppbarBackground = "#1e1b4b",
            AppbarText = "#e2e8f0",
            TextPrimary = "#f1f5f9",
            TextSecondary = "#94a3b8",
            TextDisabled = "#64748b",
            Divider = "#334155",
            DividerLight = "#1e293b",
            ActionDefault = "#94a3b8",
            ActionDisabled = "#475569",
            LinesDefault = "#334155",
            LinesInputs = "#334155",
            TableLines = "#334155",
            TableHover = "#1e293b",
        },
        Typography = new Typography()
        {
            Default = new Default()
            {
                FontFamily = new[] { "Roboto", "Helvetica Neue", "Helvetica", "Arial", "sans-serif" },
            },
            H4 = new H4()
            {
                FontWeight = 600,
            },
            H6 = new H6()
            {
                FontWeight = 600,
            },
        }
    };

    protected override void OnInitialized()
    {
        ThemeService.OnThemeChanged += OnThemeChanged;
    }

    private void OnThemeChanged()
    {
        StateHasChanged();
    }

    public void Dispose()
    {
        ThemeService.OnThemeChanged -= OnThemeChanged;
    }
}