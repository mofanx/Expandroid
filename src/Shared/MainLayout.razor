@inherits LayoutComponentBase
@inject IThemeService ThemeService
@implements IDisposable

<MudThemeProvider IsDarkMode="@ThemeService.IsDarkMode" Theme="MudAppTheme"/>
<MudDialogProvider/>
<MudSnackbarProvider/>

<MudLayout>
    <TopBar />
    <MudMainContent Class="pt-16">
        <MudContainer MaxWidth="MaxWidth.Medium" Class="pa-4 app-content">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private MudTheme MudAppTheme = new()
    {
        Palette = new Palette()
        {
            Primary = "#6366f1",
            Secondary = "#8b5cf6",
            Success = "#10b981",
            Error = "#f43f5e",
            Background = "#f8fafc",
            Surface = "#ffffff",
            AppbarBackground = "#6366f1",
            AppbarText = "#ffffff",
            TextPrimary = "#1e293b",
        },
        PaletteDark = new Palette()
        {
            Primary = "#818cf8",
            Secondary = "#a78bfa",
            Success = "#34d399",
            Error = "#fb7185",
            Background = "#0f172a",
            Surface = "#1e293b",
            AppbarBackground = "#1e293b",
            AppbarText = "#f1f5f9",
            TextPrimary = "#f1f5f9",
        },
        Typography = new Typography()
        {
            Default = new Default()
            {
                FontFamily = new[] { "Roboto", "Helvetica Neue", "Helvetica", "Arial", "sans-serif" },
            },
            H4 = new H4()
            {
                FontWeight = 600,
            },
            H6 = new H6()
            {
                FontWeight = 600,
            },
        }
    };

    protected override void OnInitialized()
    {
        ThemeService.OnThemeChanged += OnThemeChanged;
    }

    private void OnThemeChanged()
    {
        StateHasChanged();
    }

    public void Dispose()
    {
        ThemeService.OnThemeChanged -= OnThemeChanged;
    }
}