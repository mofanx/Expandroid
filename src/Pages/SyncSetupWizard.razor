@page "/syncsetup"
@using Expandroid.Services
@using Expandroid.Models
@using CommunityToolkit.Maui.Storage
@using CommunityToolkit.Mvvm.Messaging
@inject SyncManager SyncManager
@inject YamlWorkspace YamlWorkspace
@inject ISnackbar Snackbar
@inject ILocalizationService localizationService
@inject NavigationManager NavigationManager
@implements IDisposable

<MudText Typo="Typo.h4" Align="Align.Center" class="mb-4">@localizationService.GetString("SetupWizardTitle")</MudText>

<MudStack Row="true" Spacing="0" Justify="@Justify.Center" Align="Align.Center" Class="mb-4">
    @for (int i = 1; i <= 3; i++)
    {
        var stepNum = i;
        <div class="step-dot @(stepNum <= _step ? "active" : "")">
            <span>@stepNum</span>
        </div>
        @if (stepNum < 3)
        {
            <div class="step-line @(stepNum < _step ? "active" : "")"></div>
        }
    }
</MudStack>

<MudCard Class="mb-4">
    <MudCardContent>
@if (_step == 1)
    {
        <MudText Typo="Typo.h6" class="mb-3">@localizationService.GetString("UseDesktopEspanso")</MudText>
        <MudStack Row="true" Spacing="3">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="() => _step = 2">@localizationService.GetString("Yes")</MudButton>
            <MudButton Color="Color.Secondary" Variant="Variant.Outlined" OnClick="SkipWizard">@localizationService.GetString("NoStartFresh")</MudButton>
        </MudStack>
    }
    else if (_step == 2)
    {
        <MudText Typo="Typo.h6" class="mb-3">@localizationService.GetString("ChooseSyncMethod")</MudText>
        <MudList Clickable="true" class="mb-3">
            <MudListItem OnClick="() => SelectMethod(SyncMethod.CloudFolder)">
                <MudText Typo="Typo.subtitle1">@localizationService.GetString("CloudFolderRecommended")</MudText>
                <MudText Typo="Typo.body2" Color="Color.Default">@localizationService.GetString("CloudFolderDesc")</MudText>
            </MudListItem>
            <MudListItem OnClick="() => SelectMethod(SyncMethod.Syncthing)">
                <MudText Typo="Typo.subtitle1">@localizationService.GetString("SyncMethodSyncthing")</MudText>
                <MudText Typo="Typo.body2" Color="Color.Default">@localizationService.GetString("SyncthingDesc")</MudText>
            </MudListItem>
            <MudListItem OnClick="() => SelectMethod(SyncMethod.WebDAV)">
                <MudText Typo="Typo.subtitle1">@localizationService.GetString("WebDavAdvanced")</MudText>
                <MudText Typo="Typo.body2" Color="Color.Default">@localizationService.GetString("WebDavDesc")</MudText>
            </MudListItem>
            <MudListItem OnClick="() => SelectMethod(SyncMethod.Git)">
                <MudText Typo="Typo.subtitle1">@localizationService.GetString("GitRepository")</MudText>
                <MudText Typo="Typo.body2" Color="Color.Default">@localizationService.GetString("GitRepoDesc")</MudText>
            </MudListItem>
            <MudListItem OnClick="() => SelectMethod(SyncMethod.Manual)">
                <MudText Typo="Typo.subtitle1">@localizationService.GetString("SyncMethodManual")</MudText>
                <MudText Typo="Typo.body2" Color="Color.Default">@localizationService.GetString("ManualDesc")</MudText>
            </MudListItem>
        </MudList>
        <MudButton Variant="Variant.Text" OnClick="() => _step = 1">@localizationService.GetString("Back")</MudButton>
    }
    else if (_step == 3)
    {
        <MudText Typo="Typo.h6" class="mb-3">@string.Format(localizationService.GetString("ConfigureMethod"), _config.Method)</MudText>

        @if (_config.Method == SyncMethod.CloudFolder)
        {
            <MudText class="mb-3">@localizationService.GetString("CloudFolderDesc")</MudText>
            <MudTextField Label="@localizationService.GetString("SyncFolderPath")" @bind-Value="_config.SyncUri" Variant="Variant.Outlined" class="mb-3" Hint="@localizationService.GetString("HintCloudFolderPath")" />
            <MudButton Color="Color.Primary" Variant="Variant.Outlined" OnClick="PickFolderAsync" class="mb-3">@localizationService.GetString("BrowseFolder")</MudButton>
        }
        else if (_config.Method == SyncMethod.Syncthing)
        {
            <MudAlert Severity="Severity.Info" Class="mb-3">
                @((MarkupString)localizationService.GetString("SyncthingSetupSteps"))
            </MudAlert>
            <MudTextField Label="@localizationService.GetString("SyncFolderPath")" @bind-Value="_config.SyncUri" Variant="Variant.Outlined" class="mb-3" />
            <MudButton Color="Color.Primary" Variant="Variant.Outlined" OnClick="PickFolderAsync" class="mb-3">@localizationService.GetString("BrowseFolder")</MudButton>
        }
        else if (_config.Method == SyncMethod.WebDAV)
        {
            <MudTextField Label="@localizationService.GetString("WebDavUrl")" @bind-Value="_config.SyncUri" Variant="Variant.Outlined" class="mb-3" Hint="@localizationService.GetString("HintWebDavUrl")" />
            <MudTextField Label="@localizationService.GetString("Username")" @bind-Value="_config.Username" Variant="Variant.Outlined" class="mb-3" />
            <MudTextField Label="@localizationService.GetString("Password")" @bind-Value="_config.Password" Variant="Variant.Outlined" InputType="InputType.Password" class="mb-3" />
            <MudButton Color="Color.Info" Variant="Variant.Outlined" OnClick="TestWebDavConnection" Disabled="@_testing" class="mb-3">
                @if (_testing) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="ms-2" /> }
                else { @localizationService.GetString("TestConnection") }
            </MudButton>
        }
        else if (_config.Method == SyncMethod.Git)
        {
            <MudTextField Label="@localizationService.GetString("GitRepoUrl")" @bind-Value="_config.SyncUri" Variant="Variant.Outlined" class="mb-3" Hint="@localizationService.GetString("HintGitRepoUrl")" />
            <MudTextField Label="@localizationService.GetString("GitUsername")" @bind-Value="_config.Username" Variant="Variant.Outlined" class="mb-3" Hint="@localizationService.GetString("HintGitUsername")" />
            <MudTextField Label="@localizationService.GetString("PersonalAccessToken")" @bind-Value="_config.Password" Variant="Variant.Outlined" InputType="InputType.Password" class="mb-3" />
            <MudTextField Label="@localizationService.GetString("GitBranch")" @bind-Value="_config.GitBranch" Variant="Variant.Outlined" class="mb-3" />
            <MudAlert Severity="@(_termuxAvailable ? Severity.Success : Severity.Warning)" Class="mb-3">
                @localizationService.GetString("RequiresTermux")
                <br /><strong>Termux: @(_termuxAvailable ? localizationService.GetString("TermuxDetected") : localizationService.GetString("TermuxNotFound"))</strong>
            </MudAlert>
        }

        <MudStack Row="true" Spacing="3">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="FinishSetup">@localizationService.GetString("Finish")</MudButton>
            <MudButton Variant="Variant.Text" OnClick="() => _step = 2">@localizationService.GetString("Back")</MudButton>
        </MudStack>
    }
    </MudCardContent>
</MudCard>

@code {
    private int _step = 1;
    private SyncConfig _config;
    private bool _testing = false;
    private bool _termuxAvailable = false;

    protected override void OnInitialized()
    {
        _config = SyncManager.GetConfig();
        if (_config.Method == SyncMethod.Git)
        {
            _termuxAvailable = SyncManager.IsTermuxAvailable();
        }
        localizationService.OnLanguageChanged += OnLanguageChanged;
    }

    private void OnLanguageChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void SelectMethod(SyncMethod method)
    {
        _config.Method = method;
        if (method == SyncMethod.Git)
        {
            _termuxAvailable = SyncManager.IsTermuxAvailable();
        }
        _step = 3;
    }

    private async Task TestWebDavConnection()
    {
        if (string.IsNullOrEmpty(_config.SyncUri))
        {
            Snackbar.Add(localizationService.GetString("PleaseEnterWebDavUrl"), Severity.Warning);
            return;
        }
        _testing = true;
        try
        {
            var (ok, error) = await SyncManager.TestWebDavConnectionAsync(_config.SyncUri, _config.Username, _config.Password);
            if (ok)
                Snackbar.Add(localizationService.GetString("ConnectionSuccessful"), Severity.Success);
            else
                Snackbar.Add($"{localizationService.GetString("ConnectionFailed")} {error}", Severity.Error);
        }
        finally
        {
            _testing = false;
        }
    }

    private async Task PickFolderAsync()
    {
        try
        {
            var result = await FolderPicker.Default.PickAsync(CancellationToken.None);
            if (result.Folder is not null)
            {
                var folderPath = result.Folder.Path;
                _config.SyncUri = folderPath;

#if ANDROID
                if (folderPath.StartsWith("content://"))
                {
                    try
                    {
                        var safManager = new SafManager(Android.App.Application.Context);
                        safManager.TakePersistableUriPermission(folderPath);
                    }
                    catch { }
                }
#endif
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(string.Format(localizationService.GetString("ErrorWithDetail"), ex.Message), Severity.Error);
        }
    }

    private void FinishSetup()
    {
        if (string.IsNullOrEmpty(_config.SyncUri) && _config.Method != SyncMethod.Manual)
        {
            var msg = _config.Method switch
            {
                SyncMethod.WebDAV => localizationService.GetString("PleaseEnterWebDavUrl"),
                SyncMethod.Git => localizationService.GetString("PleaseEnterGitRepoUrl"),
                _ => localizationService.GetString("PleaseSelectSyncFolder")
            };
            Snackbar.Add(msg, Severity.Warning);
            return;
        }

        SyncManager.UpdateConfig(_config);

        if (_config.Method != SyncMethod.None && _config.Method != SyncMethod.Manual)
        {
#if ANDROID
            SyncWorker.SchedulePeriodicSync(_config.BackgroundPollIntervalMin);
#endif
        }

        WeakReferenceMessenger.Default.Send(new ConfigChangedMessage());
        Snackbar.Add(localizationService.GetString("SyncConfigured"), Severity.Success);
        NavigationManager.NavigateTo("/");
    }

    private void SkipWizard()
    {
        NavigationManager.NavigateTo("/");
    }

    public void Dispose()
    {
        localizationService.OnLanguageChanged -= OnLanguageChanged;
    }
}
