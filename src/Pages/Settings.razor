@page "/settings"
@using EspansoGo.Models
@using CommunityToolkit.Mvvm.Messaging
@inject IThemeService ThemeService
@inject ILocalizationService LocalizationService
@inject NavigationManager NavigationManager
@inject ICheckIfActivated AcService
@inject ISnackbar Snackbar
@implements IDisposable

<MudPaper Elevation="0" Class="settings-container">
    <MudList DisablePadding="true">
        <!-- Appearance Section -->
        <MudListItem Class="px-4 py-2">
            <MudText Typo="Typo.caption" Class="mb-1" Style="opacity: 0.6; font-weight: 500;">@LocalizationService.GetString("Appearance")</MudText>
        </MudListItem>
        <MudListItem Class="px-4 py-3">
            <MudStack Spacing="2" Style="width: 100%;">
                <MudStack Row="true" Align="Align.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Palette" Size="Size.Small" Color="Color.Primary" />
                    <MudText Typo="Typo.body2">@LocalizationService.GetString("Theme")</MudText>
                </MudStack>
                <MudRadioGroup T="string" Value="_themeValue" ValueChanged="@((string v) => OnThemeChanged(v))" Class="ml-4">
                    <MudRadioItem Value="@("light")" Label="@LocalizationService.GetString("ThemeLight")">
                        <MudIcon Icon="@Icons.Material.Filled.WbSunny" Size="Size.Small" Class="mr-2" />
                    </MudRadioItem>
                    <MudRadioItem Value="@("dark")" Label="@LocalizationService.GetString("ThemeDark")">
                        <MudIcon Icon="@Icons.Material.Filled.NightsStay" Size="Size.Small" Class="mr-2" />
                    </MudRadioItem>
                    <MudRadioItem Value="@("auto")" Label="@LocalizationService.GetString("ThemeAuto")">
                        <MudIcon Icon="@Icons.Material.Filled.BrightnessAuto" Size="Size.Small" Class="mr-2" />
                    </MudRadioItem>
                </MudRadioGroup>
            </MudStack>
        </MudListItem>
        <MudListItem Class="px-4 py-3">
            <MudStack Spacing="2" Style="width: 100%;">
                <MudStack Row="true" Align="Align.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Language" Size="Size.Small" Color="Color.Primary" />
                    <MudText Typo="Typo.body2">@LocalizationService.GetString("Language")</MudText>
                </MudStack>
                <MudRadioGroup T="string" Value="_currentLang" ValueChanged="ChangeLanguage" Class="ml-4">
                    @foreach (var lang in LocalizationService.GetAvailableLanguages())
                    {
                        <MudRadioItem Value="@lang.Code" Label="@lang.NativeName" />
                    }
                </MudRadioGroup>
            </MudStack>
        </MudListItem>

        <MudDivider />

        <!-- Sync Section -->
        <MudListItem Class="px-4 py-2">
            <MudText Typo="Typo.caption" Class="mb-1" Style="opacity: 0.6; font-weight: 500;">@LocalizationService.GetString("Sync")</MudText>
        </MudListItem>
        <MudListItem Clickable="true" OnClick="GoSyncSettings" Class="px-4 py-3">
            <MudStack Row="true" Align="Align.Center" Justify="@Justify.SpaceBetween" Style="width: 100%;">
                <MudStack Row="true" Align="Align.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Sync" Size="Size.Small" Color="Color.Primary" />
                    <MudText Typo="Typo.body2">@LocalizationService.GetString("SyncSettings")</MudText>
                </MudStack>
                <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" Style="opacity: 0.4;" />
            </MudStack>
        </MudListItem>

        <MudDivider />

        <!-- Advanced Section -->
        <MudListItem Class="px-4 py-2">
            <MudText Typo="Typo.caption" Class="mb-1" Style="opacity: 0.6; font-weight: 500;">@LocalizationService.GetString("Advanced")</MudText>
        </MudListItem>
        <MudListItem Clickable="true" OnClick="GoGlobalVars" Class="px-4 py-3">
            <MudStack Row="true" Align="Align.Center" Justify="@Justify.SpaceBetween" Style="width: 100%;">
                <MudStack Row="true" Align="Align.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.DataObject" Size="Size.Small" Color="Color.Primary" />
                    <MudText Typo="Typo.body2">@LocalizationService.GetString("GlobalVariables")</MudText>
                </MudStack>
                <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" Style="opacity: 0.4;" />
            </MudStack>
        </MudListItem>

        <MudDivider />

        <!-- Accessibility Service Section -->
        <MudListItem Class="px-4 py-2">
            <MudText Typo="Typo.caption" Class="mb-1" Style="opacity: 0.6; font-weight: 500;">@LocalizationService.GetString("AccessibilityService")</MudText>
        </MudListItem>
        <!-- Accessibility Service Toggle -->
        <MudListItem Class="px-4 py-3">
            <MudStack Row="true" Align="Align.Center" Justify="@Justify.SpaceBetween" Style="width: 100%;">
                <MudStack Row="true" Align="Align.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.AccessibilityNew" Size="Size.Small" Color="Color.Primary" />
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.body2">@LocalizationService.GetString("AccessibilityService")</MudText>
                        <MudText Typo="Typo.caption" Style="opacity: 0.5; font-size: 0.65rem;">@LocalizationService.GetString("AccessibilityDescription")</MudText>
                    </MudStack>
                </MudStack>
                <MudSwitch T="bool" @bind-Value="@_accessibilityEnabled" @bind-Value:after="OnAccessibilityToggled" Color="Color.Primary" Disabled="@_enabling" Dense="true" />
            </MudStack>
        </MudListItem>

        <!-- Shizuku Toggle -->
        @if (_shizukuAvailable)
        {
            <MudListItem Class="px-4 py-3">
                <MudStack Row="true" Align="Align.Center" Justify="@Justify.SpaceBetween" Style="width: 100%;">
                    <MudStack Row="true" Align="Align.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.Android" Size="Size.Small" Color="Color.Secondary" />
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body2">@LocalizationService.GetString("ShizukuOptimization")</MudText>
                            <MudText Typo="Typo.caption" Style="opacity: 0.5; font-size: 0.65rem;">@LocalizationService.GetString("ShizukuDescription")</MudText>
                        </MudStack>
                    </MudStack>
                    <MudSwitch T="bool" @bind-Value="@_useShizuku" @bind-Value:after="OnUseShizukuChanged" Color="Color.Secondary" Dense="true" />
                </MudStack>
            </MudListItem>
        }

        <!-- Shizuku Hint -->
        @if (!_shizukuAvailable && !_shizukuHintDismissed)
        {
            <MudListItem Class="px-4 py-3">
                <MudAlert Severity="Severity.Info" Dense="true" Elevation="0" Class="alert-compact" ShowDismissIcon="true" Dismissed="@(_shizukuHintDismissed)"
                          DismissedChanged="@(EventCallback.Factory.Create<bool>(this, v => { _shizukuHintDismissed = v; Microsoft.Maui.Storage.Preferences.Set("shizuku_hint_dismissed", v); StateHasChanged(); }))">
                    <MudText Typo="Typo.caption">@LocalizationService.GetString("ShizukuHint")</MudText>
                    <MudButton Variant="Variant.Text" Color="Color.Info" Size="Size.Small" OnClick="OpenShizukuWebsite" Class="pa-0">
                        @LocalizationService.GetString("LearnMore")
                    </MudButton>
                </MudAlert>
            </MudListItem>
        }

        <MudDivider />

        <!-- About Section -->
        <MudListItem Class="px-4 py-2">
            <MudText Typo="Typo.caption" Class="mb-1" Style="opacity: 0.6; font-weight: 500;">@LocalizationService.GetString("About")</MudText>
        </MudListItem>
        <MudListItem Clickable="true" OnClick="QuitApp" Class="px-4 py-3">
            <MudStack Row="true" Align="Align.Center" Justify="@Justify.SpaceBetween" Style="width: 100%;">
                <MudStack Row="true" Align="Align.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.PowerSettingsNew" Size="Size.Small" Color="Color.Error" />
                    <MudText Typo="Typo.body2" Color="Color.Error">@LocalizationService.GetString("QuitApp")</MudText>
                </MudStack>
            </MudStack>
        </MudListItem>
    </MudList>
</MudPaper>

<style>
    .settings-container {
        background-color: var(--mud-palette-surface);
    }
    .alert-compact {
        background-color: rgba(var(--mud-palette-info-rgb), 0.08);
    }
</style>

@code {
    private string _themeValue = "auto";
    private string _currentLang = "en";
    private bool _accessibilityEnabled = false;
    private bool _enabling = false;
    private bool _shizukuAvailable = false;
    private bool _shizukuHintDismissed = false;
    private bool _useShizuku = false;

    protected override void OnInitialized()
    {
        UpdateThemeValue();
        _currentLang = LocalizationService.CurrentCulture.Name.StartsWith("zh") ? "zh" : "en";
        ThemeService.OnThemeChanged += UpdateThemeValue;
        LocalizationService.OnLanguageChanged += OnLanguageChanged;
        _shizukuHintDismissed = Microsoft.Maui.Storage.Preferences.Get("shizuku_hint_dismissed", false);
        _useShizuku = Microsoft.Maui.Storage.Preferences.Get("use_shizuku", false);
        _ = CheckAccessibilityStatusAsync();
        WeakReferenceMessenger.Default.Register<AppResumedMessage>(this, (r, m) =>
        {
            InvokeAsync(() => CheckAccessibilityStatusAsync());
        });
    }

    private void OnUseShizukuChanged()
    {
        Microsoft.Maui.Storage.Preferences.Set("use_shizuku", _useShizuku);
    }

    private void OnLanguageChanged()
    {
        InvokeAsync(() =>
        {
            _currentLang = LocalizationService.CurrentCulture.Name.StartsWith("zh") ? "zh" : "en";
            StateHasChanged();
        });
    }

    private void UpdateThemeValue()
    {
        _themeValue = ThemeService.CurrentTheme switch
        {
            AppTheme.Light => "light",
            AppTheme.Dark => "dark",
            _ => "auto"
        };
        StateHasChanged();
    }

    private void OnThemeChanged(string value)
    {
        var theme = value switch
        {
            "light" => AppTheme.Light,
            "dark" => AppTheme.Dark,
            _ => AppTheme.Auto
        };
        ThemeService.SetTheme(theme);
    }

    private void ChangeLanguage(string lang)
    {
        _currentLang = lang;
        LocalizationService.SetCulture(lang);
    }

    private void GoSyncSettings() => NavigationManager.NavigateTo("/syncsettings");
    private void GoGlobalVars() => NavigationManager.NavigateTo("/globalvars");

    private async Task CheckAccessibilityStatusAsync()
    {
        await Task.Run(() =>
        {
            _accessibilityEnabled = AcService.IsActivated();
            _shizukuAvailable = AcService.IsShizukuAvailable();
        });
        StateHasChanged();
    }

    private async Task OnAccessibilityToggled()
    {
        _enabling = true;
        StateHasChanged();
        try
        {
            if (_accessibilityEnabled)
            {
                // Enable accessibility
                // If Shizuku is available and enabled, try to use it first
                if (_shizukuAvailable && _useShizuku)
                {
                    // Try to grant Shizuku authorization if not authorized
                    if (!AcService.IsShizukuAuthorized())
                    {
                        await AcService.RequestShizukuAuthorization();
                        // Wait a moment for permission result
                        await Task.Delay(500);
                        // Re-check authorization status
                        if (!AcService.IsShizukuAuthorized())
                        {
                            Snackbar.Add(LocalizationService.GetString("ShizukuAuthNeeded"), Severity.Info);
                            AcService.OpenSettings();
                            _accessibilityEnabled = false;
                            StateHasChanged();
                            return;
                        }
                    }

                    // Try to enable accessibility via Shizuku
                    var enabled = await AcService.TryEnableAccessibility();
                    if (!enabled)
                    {
                        Snackbar.Add("Failed to enable accessibility via Shizuku", Severity.Warning);
                        _accessibilityEnabled = false;
                        StateHasChanged();
                        return;
                    }
                    else
                    {
                        Snackbar.Add(LocalizationService.GetString("AccessibilityEnabled"), Severity.Success);
                    }
                }
                else
                {
                    // Fallback: open system settings
                    AcService.OpenSettings();
                    _accessibilityEnabled = false;
                    StateHasChanged();
                    return;
                }
            }
            else
            {
                // Disable accessibility
                // If Shizuku is available and enabled, try to use it first
                if (_shizukuAvailable && _useShizuku)
                {
                    var disabled = await AcService.TryDisableAccessibility();
                    if (!disabled)
                    {
                        Snackbar.Add("Failed to disable accessibility via Shizuku", Severity.Warning);
                        _accessibilityEnabled = true;
                        StateHasChanged();
                        return;
                    }
                    else
                    {
                        Snackbar.Add(LocalizationService.GetString("AccessibilityDisabled"), Severity.Success);
                    }
                }
                else
                {
                    // Fallback: open system settings
                    AcService.OpenSettings();
                    _accessibilityEnabled = true;
                    StateHasChanged();
                    return;
                }
            }
        }
        catch (Exception e)
        {
            Snackbar.Add(e.Message, Severity.Error);
            _accessibilityEnabled = !_accessibilityEnabled;
            StateHasChanged();
        }
        finally
        {
            _enabling = false;
            StateHasChanged();
        }
    }

    private async Task OpenShizukuWebsite()
    {
        try
        {
            var url = "https://shizuku.fankes.top/";
            await Microsoft.Maui.ApplicationModel.Browser.OpenAsync(url);
        }
        catch { }
    }

    private void QuitApp() => Application.Current?.Quit();

    public void Dispose()
    {
        ThemeService.OnThemeChanged -= UpdateThemeValue;
        LocalizationService.OnLanguageChanged -= OnLanguageChanged;
        WeakReferenceMessenger.Default.Unregister<AppResumedMessage>(this);
    }
}
