@page "/settings"
@using EspansoGo.Models
@using CommunityToolkit.Mvvm.Messaging
@inject IThemeService ThemeService
@inject ILocalizationService LocalizationService
@inject NavigationManager NavigationManager
@inject ICheckIfActivated AcService
@inject ISnackbar Snackbar
@implements IDisposable

<MudStack Spacing="3">
    <MudText Typo="Typo.h5" Class="mt-2 mb-1">@LocalizationService.GetString("Appearance")</MudText>
    <MudPaper Elevation="1" Class="pa-4">
        <MudList>
            <MudListItem>
                <MudStack Row="true" Align="Align.Center" Justify="@Justify.SpaceBetween" Style="width: 100%;">
                    <MudStack Row="true" Align="Align.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.Palette" Color="Color.Primary" />
                        <MudText Typo="Typo.subtitle1">@LocalizationService.GetString("Theme")</MudText>
                    </MudStack>
                    <MudToggleGroup Value="_themeValue" ValueChanged="@((string v) => OnThemeChanged(v))" Color="Color.Primary" Size="Size.Small">
                        <MudToggleItem Value="@("light")" Icon="@Icons.Material.Filled.WbSunny" />
                        <MudToggleItem Value="@("dark")" Icon="@Icons.Material.Filled.NightsStay" />
                        <MudToggleItem Value="@("auto")" Icon="@Icons.Material.Filled.BrightnessAuto" />
                    </MudToggleGroup>
                </MudStack>
            </MudListItem>
            <MudListItem>
                <MudStack Row="true" Align="Align.Center" Justify="@Justify.SpaceBetween" Style="width: 100%;">
                    <MudStack Row="true" Align="Align.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.Language" Color="Color.Primary" />
                        <MudText Typo="Typo.subtitle1">@LocalizationService.GetString("Language")</MudText>
                    </MudStack>
                    <MudSelect T="string" Value="@_currentLang" ValueChanged="ChangeLanguage" Variant="Variant.Outlined" Dense="true" Style="min-width: 120px;">
                        @foreach (var lang in LocalizationService.GetAvailableLanguages())
                        {
                            <MudSelectItem T="string" Value="@lang.Code">@lang.NativeName</MudSelectItem>
                        }
                    </MudSelect>
                </MudStack>
            </MudListItem>
        </MudList>
    </MudPaper>

    <MudText Typo="Typo.h5" Class="mt-2 mb-1">@LocalizationService.GetString("Sync")</MudText>
    <MudPaper Elevation="1" Class="pa-4">
        <MudList>
            <MudListItem Clickable="true" OnClick="GoSyncSettings">
                <MudStack Row="true" Align="Align.Center" Justify="@Justify.SpaceBetween" Style="width: 100%;">
                    <MudStack Row="true" Align="Align.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.Sync" Color="Color.Primary" />
                        <MudText Typo="Typo.subtitle1">@LocalizationService.GetString("SyncSettings")</MudText>
                    </MudStack>
                    <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Style="opacity: 0.5;" />
                </MudStack>
            </MudListItem>
        </MudList>
    </MudPaper>

    <MudText Typo="Typo.h5" Class="mt-2 mb-1">@LocalizationService.GetString("Advanced")</MudText>
    <MudPaper Elevation="1" Class="pa-4">
        <MudList>
            <MudListItem Clickable="true" OnClick="GoGlobalVars">
                <MudStack Row="true" Align="Align.Center" Justify="@Justify.SpaceBetween" Style="width: 100%;">
                    <MudStack Row="true" Align="Align.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.DataObject" Color="Color.Primary" />
                        <MudText Typo="Typo.subtitle1">@LocalizationService.GetString("GlobalVariables")</MudText>
                    </MudStack>
                    <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Style="opacity: 0.5;" />
                </MudStack>
            </MudListItem>
        </MudList>
    </MudPaper>

    <MudText Typo="Typo.h5" Class="mt-2 mb-1">@LocalizationService.GetString("AccessibilityService")</MudText>
    <MudPaper Elevation="1" Class="pa-4">
        <MudStack Spacing="2">
            <MudStack Row="true" Align="Align.Center" Justify="@Justify.SpaceBetween">
                <MudStack Row="true" Align="Align.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.AccessibilityNew" Color="Color.Primary" />
                    <MudText Typo="Typo.subtitle1">@LocalizationService.GetString("AccessibilityService")</MudText>
                </MudStack>
                @if (_accessibilityEnabled)
                {
                    <MudChip Color="Color.Success" Size="Size.Small">@LocalizationService.GetString("AccessibilityStatusEnabled")</MudChip>
                }
                else
                {
                    <MudChip Color="Color.Warning" Size="Size.Small">@LocalizationService.GetString("AccessibilityNotEnabled")</MudChip>
                }
            </MudStack>

            @if (!_accessibilityEnabled)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="EnableAccessibility" Disabled="@_enabling"
                           StartIcon="@Icons.Material.Filled.PowerSettingsNew">
                    @if (_enabling) { @LocalizationService.GetString("Enabling") } else { @LocalizationService.GetString("OneClickEnable") }
                </MudButton>

                @if (!_shizukuAvailable && !_shizukuHintDismissed)
                {
                    <MudAlert Severity="Severity.Info" Class="mt-2" ShowDismissIcon="true" Dismissed="@(_shizukuHintDismissed)"
                              DismissedChanged="@(v => { _shizukuHintDismissed = v; Microsoft.Maui.Storage.Preferences.Set("shizuku_hint_dismissed", v); StateHasChanged(); })">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.body2">@LocalizationService.GetString("ShizukuHint")</MudText>
                            <MudButton Variant="Variant.Text" Color="Color.Info" Size="Size.Small" OnClick="OpenShizukuWebsite">
                                @LocalizationService.GetString("LearnMore")
                            </MudButton>
                        </MudStack>
                    </MudAlert>
                }
            }
        </MudStack>
    </MudPaper>

    <MudText Typo="Typo.h5" Class="mt-2 mb-1">@LocalizationService.GetString("About")</MudText>
    <MudPaper Elevation="1" Class="pa-4">
        <MudList>
            <MudListItem Clickable="true" OnClick="QuitApp">
                <MudStack Row="true" Align="Align.Center" Justify="@Justify.SpaceBetween" Style="width: 100%;">
                    <MudStack Row="true" Align="Align.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.PowerSettingsNew" Color="Color.Error" />
                        <MudText Typo="Typo.subtitle1" Color="Color.Error">@LocalizationService.GetString("QuitApp")</MudText>
                    </MudStack>
                </MudStack>
            </MudListItem>
        </MudList>
    </MudPaper>
</MudStack>

@code {
    private string _themeValue = "auto";
    private string _currentLang = "en";
    private bool _accessibilityEnabled = false;
    private bool _enabling = false;
    private bool _shizukuAvailable = false;
    private bool _shizukuHintDismissed = false;

    protected override void OnInitialized()
    {
        UpdateThemeValue();
        _currentLang = LocalizationService.CurrentCulture.Name.StartsWith("zh") ? "zh" : "en";
        ThemeService.OnThemeChanged += UpdateThemeValue;
        LocalizationService.OnLanguageChanged += OnLanguageChanged;
        _shizukuHintDismissed = Microsoft.Maui.Storage.Preferences.Get("shizuku_hint_dismissed", false);
        _ = CheckAccessibilityStatusAsync();
        WeakReferenceMessenger.Default.Register<AppResumedMessage>(this, (r, m) =>
        {
            InvokeAsync(() => CheckAccessibilityStatusAsync());
        });
    }

    private void OnLanguageChanged()
    {
        InvokeAsync(() =>
        {
            _currentLang = LocalizationService.CurrentCulture.Name.StartsWith("zh") ? "zh" : "en";
            StateHasChanged();
        });
    }

    private void UpdateThemeValue()
    {
        _themeValue = ThemeService.CurrentTheme switch
        {
            AppTheme.Light => "light",
            AppTheme.Dark => "dark",
            _ => "auto"
        };
        StateHasChanged();
    }

    private void OnThemeChanged(string value)
    {
        var theme = value switch
        {
            "light" => AppTheme.Light,
            "dark" => AppTheme.Dark,
            _ => AppTheme.Auto
        };
        ThemeService.SetTheme(theme);
    }

    private void ChangeLanguage(string lang)
    {
        _currentLang = lang;
        LocalizationService.SetCulture(lang);
    }

    private void GoSyncSettings() => NavigationManager.NavigateTo("/syncsettings");
    private void GoGlobalVars() => NavigationManager.NavigateTo("/globalvars");

    private async Task CheckAccessibilityStatusAsync()
    {
        await Task.Run(() =>
        {
            _accessibilityEnabled = AcService.IsActivated();
            _shizukuAvailable = AcService.IsShizukuAvailable();
        });
        StateHasChanged();
    }

    private async Task EnableAccessibility()
    {
        _enabling = true;
        StateHasChanged();
        try
        {
            if (_shizukuAvailable)
            {
                if (!AcService.IsShizukuAuthorized())
                {
                    await AcService.RequestShizukuAuthorization();
                    // Permission result is async (system dialog). User may not have granted yet.
                    // Fallback to system settings for now; once Shizuku bindUserService is implemented,
                    // we can retry TryEnableAccessibility after a short delay.
                    Snackbar.Add(LocalizationService.GetString("ShizukuAuthNeeded"), Severity.Info);
                    AcService.OpenSettings();
                    return;
                }
                var enabled = await AcService.TryEnableAccessibility();
                if (enabled)
                {
                    _accessibilityEnabled = true;
                    Snackbar.Add(LocalizationService.GetString("AccessibilityEnabled"), Severity.Success);
                    return;
                }
            }
            // Fallback: open system settings
            AcService.OpenSettings();
        }
        catch (Exception e)
        {
            Snackbar.Add(e.Message, Severity.Error);
        }
        finally
        {
            _enabling = false;
            StateHasChanged();
        }
    }

    private void OpenShizukuWebsite()
    {
        try
        {
            var url = "https://shizuku.fankes.top/";
            Microsoft.Maui.ApplicationModel.Browser.OpenAsync(url);
        }
        catch { }
    }

    private void QuitApp() => Application.Current?.Quit();

    public void Dispose()
    {
        ThemeService.OnThemeChanged -= UpdateThemeValue;
        LocalizationService.OnLanguageChanged -= OnLanguageChanged;
        WeakReferenceMessenger.Default.Unregister<AppResumedMessage>(this);
    }
}
