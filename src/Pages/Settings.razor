@page "/settings"
@using EspansoGo.Models
@using CommunityToolkit.Mvvm.Messaging
@inject IThemeService ThemeService
@inject ILocalizationService LocalizationService
@inject NavigationManager NavigationManager
@inject ICheckIfActivated AcService
@inject ISnackbar Snackbar
@implements IDisposable

<MudStack Spacing="4" Class="pa-3">
    <!-- Appearance Section -->
    <MudText Typo="Typo.h6" Class="mb-2" Style="opacity: 0.7;">@LocalizationService.GetString("Appearance")</MudText>
    <MudPaper Elevation="0" Class="rounded-lg overflow-hidden">
        <MudList DisablePadding="true">
            <MudListItem Class="px-4 py-3">
                <MudStack Row="true" Align="Align.Center" Justify="@Justify.SpaceBetween" Style="width: 100%;">
                    <MudStack Row="true" Align="Align.Center" Spacing="3">
                        <MudIcon Icon="@Icons.Material.Filled.Palette" Size="Size.Medium" Color="Color.Primary" />
                        <MudText Typo="Typo.body1" Class="font-weight-medium">@LocalizationService.GetString("Theme")</MudText>
                    </MudStack>
                    <MudToggleGroup Value="_themeValue" ValueChanged="@((string v) => OnThemeChanged(v))" Color="Color.Primary" Dense="true">
                        <MudToggleItem Value="@("light")" Icon="@Icons.Material.Filled.WbSunny" />
                        <MudToggleItem Value="@("dark")" Icon="@Icons.Material.Filled.NightsStay" />
                        <MudToggleItem Value="@("auto")" Icon="@Icons.Material.Filled.BrightnessAuto" />
                    </MudToggleGroup>
                </MudStack>
            </MudListItem>
            <MudDivider />
            <MudListItem Class="px-4 py-3">
                <MudStack Row="true" Align="Align.Center" Justify="@Justify.SpaceBetween" Style="width: 100%;">
                    <MudStack Row="true" Align="Align.Center" Spacing="3">
                        <MudIcon Icon="@Icons.Material.Filled.Language" Size="Size.Medium" Color="Color.Primary" />
                        <MudText Typo="Typo.body1" Class="font-weight-medium">@LocalizationService.GetString("Language")</MudText>
                    </MudStack>
                    <MudSelect T="string" Value="@_currentLang" ValueChanged="ChangeLanguage" Variant="Variant.Outlined" Dense="true" Style="min-width: 120px;" Class="select-small">
                        @foreach (var lang in LocalizationService.GetAvailableLanguages())
                        {
                            <MudSelectItem T="string" Value="@lang.Code">@lang.NativeName</MudSelectItem>
                        }
                    </MudSelect>
                </MudStack>
            </MudListItem>
        </MudList>
    </MudPaper>

    <!-- Sync Section -->
    <MudText Typo="Typo.h6" Class="mb-2 mt-4" Style="opacity: 0.7;">@LocalizationService.GetString("Sync")</MudText>
    <MudPaper Elevation="0" Class="rounded-lg overflow-hidden">
        <MudList DisablePadding="true">
            <MudListItem Clickable="true" OnClick="GoSyncSettings" Class="px-4 py-3">
                <MudStack Row="true" Align="Align.Center" Justify="@Justify.SpaceBetween" Style="width: 100%;">
                    <MudStack Row="true" Align="Align.Center" Spacing="3">
                        <MudIcon Icon="@Icons.Material.Filled.Sync" Size="Size.Medium" Color="Color.Primary" />
                        <MudText Typo="Typo.body1" Class="font-weight-medium">@LocalizationService.GetString("SyncSettings")</MudText>
                    </MudStack>
                    <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" Style="opacity: 0.5;" />
                </MudStack>
            </MudListItem>
        </MudList>
    </MudPaper>

    <!-- Advanced Section -->
    <MudText Typo="Typo.h6" Class="mb-2 mt-4" Style="opacity: 0.7;">@LocalizationService.GetString("Advanced")</MudText>
    <MudPaper Elevation="0" Class="rounded-lg overflow-hidden">
        <MudList DisablePadding="true">
            <MudListItem Clickable="true" OnClick="GoGlobalVars" Class="px-4 py-3">
                <MudStack Row="true" Align="Align.Center" Justify="@Justify.SpaceBetween" Style="width: 100%;">
                    <MudStack Row="true" Align="Align.Center" Spacing="3">
                        <MudIcon Icon="@Icons.Material.Filled.DataObject" Size="Size.Medium" Color="Color.Primary" />
                        <MudText Typo="Typo.body1" Class="font-weight-medium">@LocalizationService.GetString("GlobalVariables")</MudText>
                    </MudStack>
                    <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" Style="opacity: 0.5;" />
                </MudStack>
            </MudListItem>
        </MudList>
    </MudPaper>

    <!-- Accessibility Service Section -->
    <MudText Typo="Typo.h6" Class="mb-2 mt-4" Style="opacity: 0.7;">@LocalizationService.GetString("AccessibilityService")</MudText>
    <MudPaper Elevation="0" Class="rounded-lg overflow-hidden">
        <MudList DisablePadding="true">
            <!-- Accessibility Service Toggle -->
            <MudListItem Class="px-4 py-3">
                <MudStack Row="true" Align="Align.Center" Justify="@Justify.SpaceBetween" Style="width: 100%;">
                    <MudStack Row="true" Align="Align.Center" Spacing="3">
                        <MudIcon Icon="@Icons.Material.Filled.AccessibilityNew" Size="Size.Medium" Color="Color.Primary" />
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body1" Class="font-weight-medium">@LocalizationService.GetString("AccessibilityService")</MudText>
                            <MudText Typo="Typo.caption" Style="opacity: 0.6;">@LocalizationService.GetString("AccessibilityDescription")</MudText>
                        </MudStack>
                    </MudStack>
                    <MudSwitch T="bool" @bind-Checked="@_accessibilityEnabled" @bind-Checked:after="OnAccessibilityToggled" Color="Color.Primary" Disabled="@_enabling" />
                </MudStack>
            </MudListItem>

            <!-- Shizuku Toggle -->
            @if (_shizukuAvailable)
            {
                <MudDivider />
                <MudListItem Class="px-4 py-3">
                    <MudStack Row="true" Align="Align.Center" Justify="@Justify.SpaceBetween" Style="width: 100%;">
                        <MudStack Row="true" Align="Align.Center" Spacing="3">
                            <MudIcon Icon="@Icons.Material.Filled.Android" Size="Size.Medium" Color="Color.Secondary" />
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.body1" Class="font-weight-medium">@LocalizationService.GetString("ShizukuOptimization")</MudText>
                                <MudText Typo="Typo.caption" Style="opacity: 0.6;">@LocalizationService.GetString("ShizukuDescription")</MudText>
                            </MudStack>
                        </MudStack>
                        <MudSwitch T="bool" @bind-Value="@_useShizuku" @bind-Value:after="OnUseShizukuChanged" Color="Color.Secondary" />
                    </MudStack>
                </MudListItem>
            }

            <!-- Shizuku Hint -->
            @if (!_shizukuAvailable && !_shizukuHintDismissed)
            {
                <MudDivider />
                <MudListItem Class="px-4 py-3">
                    <MudAlert Severity="Severity.Info" Dense="true" Elevation="0" ShowDismissIcon="true" Dismissed="@(_shizukuHintDismissed)"
                              DismissedChanged="@(EventCallback.Factory.Create<bool>(this, v => { _shizukuHintDismissed = v; Microsoft.Maui.Storage.Preferences.Set("shizuku_hint_dismissed", v); StateHasChanged(); }))">
                        <MudText Typo="Typo.body2">@LocalizationService.GetString("ShizukuHint")</MudText>
                        <MudButton Variant="Variant.Text" Color="Color.Info" Size="Size.Small" OnClick="OpenShizukuWebsite" Class="pa-0">
                            @LocalizationService.GetString("LearnMore")
                        </MudButton>
                    </MudAlert>
                </MudListItem>
            }
        </MudList>
    </MudPaper>

    <!-- About Section -->
    <MudText Typo="Typo.h6" Class="mb-2 mt-4" Style="opacity: 0.7;">@LocalizationService.GetString("About")</MudText>
    <MudPaper Elevation="0" Class="rounded-lg overflow-hidden">
        <MudList DisablePadding="true">
            <MudListItem Clickable="true" OnClick="QuitApp" Class="px-4 py-3">
                <MudStack Row="true" Align="Align.Center" Justify="@Justify.SpaceBetween" Style="width: 100%;">
                    <MudStack Row="true" Align="Align.Center" Spacing="3">
                        <MudIcon Icon="@Icons.Material.Filled.PowerSettingsNew" Size="Size.Medium" Color="Color.Error" />
                        <MudText Typo="Typo.body1" Class="font-weight-medium" Color="Color.Error">@LocalizationService.GetString("QuitApp")</MudText>
                    </MudStack>
                </MudStack>
            </MudListItem>
        </MudList>
    </MudPaper>
</MudStack>

@code {
    private string _themeValue = "auto";
    private string _currentLang = "en";
    private bool _accessibilityEnabled = false;
    private bool _enabling = false;
    private bool _shizukuAvailable = false;
    private bool _shizukuHintDismissed = false;
    private bool _useShizuku = false;

    protected override void OnInitialized()
    {
        UpdateThemeValue();
        _currentLang = LocalizationService.CurrentCulture.Name.StartsWith("zh") ? "zh" : "en";
        ThemeService.OnThemeChanged += UpdateThemeValue;
        LocalizationService.OnLanguageChanged += OnLanguageChanged;
        _shizukuHintDismissed = Microsoft.Maui.Storage.Preferences.Get("shizuku_hint_dismissed", false);
        _useShizuku = Microsoft.Maui.Storage.Preferences.Get("use_shizuku", false);
        _ = CheckAccessibilityStatusAsync();
        WeakReferenceMessenger.Default.Register<AppResumedMessage>(this, (r, m) =>
        {
            InvokeAsync(() => CheckAccessibilityStatusAsync());
        });
    }

    private void OnUseShizukuChanged()
    {
        Microsoft.Maui.Storage.Preferences.Set("use_shizuku", _useShizuku);
    }

    private void OnLanguageChanged()
    {
        InvokeAsync(() =>
        {
            _currentLang = LocalizationService.CurrentCulture.Name.StartsWith("zh") ? "zh" : "en";
            StateHasChanged();
        });
    }

    private void UpdateThemeValue()
    {
        _themeValue = ThemeService.CurrentTheme switch
        {
            AppTheme.Light => "light",
            AppTheme.Dark => "dark",
            _ => "auto"
        };
        StateHasChanged();
    }

    private void OnThemeChanged(string value)
    {
        var theme = value switch
        {
            "light" => AppTheme.Light,
            "dark" => AppTheme.Dark,
            _ => AppTheme.Auto
        };
        ThemeService.SetTheme(theme);
    }

    private void ChangeLanguage(string lang)
    {
        _currentLang = lang;
        LocalizationService.SetCulture(lang);
    }

    private void GoSyncSettings() => NavigationManager.NavigateTo("/syncsettings");
    private void GoGlobalVars() => NavigationManager.NavigateTo("/globalvars");

    private async Task CheckAccessibilityStatusAsync()
    {
        await Task.Run(() =>
        {
            _accessibilityEnabled = AcService.IsActivated();
            _shizukuAvailable = AcService.IsShizukuAvailable();
        });
        StateHasChanged();
    }

    private async Task OnAccessibilityToggled()
    {
        _enabling = true;
        StateHasChanged();
        try
        {
            if (_accessibilityEnabled)
            {
                // Enable accessibility
                // If Shizuku is available and enabled, try to use it first
                if (_shizukuAvailable && _useShizuku)
                {
                    // Try to grant Shizuku authorization if not authorized
                    if (!AcService.IsShizukuAuthorized())
                    {
                        await AcService.RequestShizukuAuthorization();
                        // Wait a moment for permission result
                        await Task.Delay(500);
                        // Re-check authorization status
                        if (!AcService.IsShizukuAuthorized())
                        {
                            Snackbar.Add(LocalizationService.GetString("ShizukuAuthNeeded"), Severity.Info);
                            AcService.OpenSettings();
                            _accessibilityEnabled = false;
                            StateHasChanged();
                            return;
                        }
                    }

                    // Try to enable accessibility via Shizuku
                    var enabled = await AcService.TryEnableAccessibility();
                    if (!enabled)
                    {
                        Snackbar.Add("Failed to enable accessibility via Shizuku", Severity.Warning);
                        _accessibilityEnabled = false;
                        StateHasChanged();
                        return;
                    }
                    else
                    {
                        Snackbar.Add(LocalizationService.GetString("AccessibilityEnabled"), Severity.Success);
                    }
                }
                else
                {
                    // Fallback: open system settings
                    AcService.OpenSettings();
                    _accessibilityEnabled = false;
                    StateHasChanged();
                    return;
                }
            }
            else
            {
                // Disable accessibility
                // If Shizuku is available and enabled, try to use it first
                if (_shizukuAvailable && _useShizuku)
                {
                    var disabled = await AcService.TryDisableAccessibility();
                    if (!disabled)
                    {
                        Snackbar.Add("Failed to disable accessibility via Shizuku", Severity.Warning);
                        _accessibilityEnabled = true;
                        StateHasChanged();
                        return;
                    }
                    else
                    {
                        Snackbar.Add(LocalizationService.GetString("AccessibilityDisabled"), Severity.Success);
                    }
                }
                else
                {
                    // Fallback: open system settings
                    AcService.OpenSettings();
                    _accessibilityEnabled = true;
                    StateHasChanged();
                    return;
                }
            }
        }
        catch (Exception e)
        {
            Snackbar.Add(e.Message, Severity.Error);
            _accessibilityEnabled = !_accessibilityEnabled;
            StateHasChanged();
        }
        finally
        {
            _enabling = false;
            StateHasChanged();
        }
    }

    private async Task OpenShizukuWebsite()
    {
        try
        {
            var url = "https://shizuku.fankes.top/";
            await Microsoft.Maui.ApplicationModel.Browser.OpenAsync(url);
        }
        catch { }
    }

    private void QuitApp() => Application.Current?.Quit();

    public void Dispose()
    {
        ThemeService.OnThemeChanged -= UpdateThemeValue;
        LocalizationService.OnLanguageChanged -= OnLanguageChanged;
        WeakReferenceMessenger.Default.Unregister<AppResumedMessage>(this);
    }
}
