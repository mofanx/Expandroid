@page "/conflicts"
@using Expandroid.Services
@using Expandroid.Models
@inject SyncManager SyncManager
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager

<MudText Typo="Typo.h4" Align="Align.Center" class="mb-4">Conflict Resolution</MudText>

@if (_conflicts.Count == 0)
{
    <MudText Align="Align.Center" class="mb-4">No conflicts detected.</MudText>
    <MudButton Variant="Variant.Outlined" OnClick="GoBack">Back</MudButton>
}
else
{
    <MudText class="mb-3">@_conflicts.Count conflict(s) found. Choose which version to keep:</MudText>

    @foreach (var conflict in _conflicts)
    {
        <MudCard Class="mb-3">
            <MudCardContent>
                <MudText Typo="Typo.h6">@conflict</MudText>
                <MudStack Row="true" Spacing="3" class="mt-3">
                    <MudButton Color="Color.Primary" Variant="Variant.Outlined" OnClick="() => KeepLocal(conflict)">
                        Keep Local
                    </MudButton>
                    <MudButton Color="Color.Secondary" Variant="Variant.Outlined" OnClick="() => KeepRemote(conflict)">
                        Keep Remote
                    </MudButton>
                </MudStack>
            </MudCardContent>
        </MudCard>
    }
}

@code {
    private List<string> _conflicts = new();

    protected override void OnInitialized()
    {
        LoadConflicts();
    }

    private void LoadConflicts()
    {
        _conflicts = SyncManager.GetConflictFiles();
    }

    private void KeepLocal(string fileName)
    {
        try
        {
            SyncManager.ResolveConflict(fileName, keepLocal: true);
            _conflicts.Remove(fileName);
            Snackbar.Add("Kept local version", Severity.Success);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private void KeepRemote(string fileName)
    {
        try
        {
            SyncManager.ResolveConflict(fileName, keepLocal: false);
            _conflicts.Remove(fileName);
            Snackbar.Add("Kept remote version", Severity.Success);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/syncsettings");
    }
}
