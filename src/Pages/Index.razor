@page "/"
@using CommunityToolkit.Maui.Storage;
@using CommunityToolkit.Mvvm.Messaging;
@using Expandroid.Models;
@using System.Text.Json;
@using System.Text;

@using YamlDotNet.Serialization;
@using YamlDotNet.Serialization.NamingConventions;
@using Expandroid.Services;
@inject Expandroid.Services.IDialogService dialogService
@inject ILocalizationService localizationService
@inject ICheckIfActivated acService
@inject IFileSaver fileSaver
@inject IFilePicker filePicker
@inject ISnackbar Snackbar
@inject SyncManager SyncManager
@inject YamlWorkspace YamlWorkspace
@inject Microsoft.AspNetCore.Components.NavigationManager NavigationManager
@implements IDisposable

@if (showWelcome)
{
    <MudAlert Severity="Severity.Info" Class="mb-4" OnClose="DismissWelcome">
        @localizationService.GetString("WelcomeMessage")
    </MudAlert>
}

<SyncStatus />

<MudText Typo="Typo.h4" Align="Align.Center" class="mb-4">
    @localizationService.GetString("AppTitle")
</MudText>
<MudTabs class="mt-3" Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-2">
    <MudTabPanel Text="@localizationService.GetString("TextExpanderTab")">
        @if (!canTextExpand)
        {
            <MudText class="mb-3">@localizationService.GetString("AccessibilityPermissionMessage")</MudText>
            <MudButton Color="Color.Primary" Variant="Variant.Outlined" @onclick="OpenSettings">@localizationService.GetString("ConsentAndOpenSettings")</MudButton>
        }
        else
        {
            <MudStack Row="true" Justify="Justify.Center" Spacing="2" Class="mb-4">
                <MudButtonGroup Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Large">
                    <MudButton @onclick="() => SaveDictAsync()" StartIcon="@Icons.Material.Filled.Save" Disabled="@_saving">
                        @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="ms-2" /> }
                        else { @localizationService.GetString("MakeSureToSave") }
                    </MudButton>
                    <MudButton @onclick="ImportAsync" StartIcon="@Icons.Material.Filled.Upload">
                        @localizationService.GetString("Import")
                    </MudButton>
                    <MudButton @onclick="ExportAsync" StartIcon="@Icons.Material.Filled.Download">
                        @localizationService.GetString("Export")
                    </MudButton>
                    <MudButton @onclick="SyncNowAsync" StartIcon="@Icons.Material.Filled.Sync" Disabled="@_syncing">
                        @if (_syncing) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="ms-2" /> }
                        else { @localizationService.GetString("Sync") }
                    </MudButton>
                </MudButtonGroup>
            </MudStack>
            <MudStack Row="true" Spacing="2" Class="mb-4">
                <MudButton @onclick='() => NavigationManager.NavigateTo("/syncsettings")'
                           Color="Color.Secondary" Variant="Variant.Text" Size="Size.Large"
                           StartIcon="@Icons.Material.Filled.Settings">
                    @localizationService.GetString("SyncSettings")
                </MudButton>
                <MudButton @onclick='() => NavigationManager.NavigateTo("/packages")'
                           Color="Color.Secondary" Variant="Variant.Text" Size="Size.Large"
                           StartIcon="@Icons.Material.Filled.Extension">
                    @localizationService.GetString("PackageStore")
                </MudButton>
                <MudButton @onclick="ForceQuit" Color="Color.Error" Variant="Variant.Outlined" Size="Size.Large"
                           StartIcon="@Icons.Material.Filled.PowerSettingsNew">
                    @localizationService.GetString("ForceQuitApp")
                </MudButton>
            </MudStack>
            <MudText class="mb-3">@localizationService.GetString("Keywords")</MudText>
            <div class="d-flex">
                <MudTextField Lines="2" class="mr-1" @bind-Value="currentMatch.Trigger" Label="@localizationService.GetString("Key")" Variant="Variant.Outlined"></MudTextField>
                <MudTextField Lines="2" class="mr-1" @bind-Value="currentMatch.Replace" Label="@localizationService.GetString("Value")" Variant="Variant.Outlined"></MudTextField>
                <MudButton @onclick="AddItemAsync" Color="Color.Primary" Variant="Variant.Text">@localizationService.GetString("Add")</MudButton>
                @if (editingKey is not null)
                {
                    <MudButton @onclick="CancelEdit" Color="Color.Default" Variant="Variant.Text">@localizationService.GetString("CancelEdit")</MudButton>
                }
            </div>
            <MudPaper class="mt-2 pa-2">
                <MudStack Row="true" Justify="@Justify.SpaceBetween" Align="Align.Center" Class="mb-2">
                    <MudText Typo="Typo.subtitle2">@localizationService.GetString("Variables")</MudText>
                    <MudChip Color="Color.Secondary" Size="Size.Small">
                        @currentMatch.Vars.Count
                    </MudChip>
                </MudStack>
                @foreach (Var item in currentMatch.Vars)
                {
                    <MudStack Row="true" Justify="@Justify.SpaceBetween" Align="Align.Center" Class="mb-1" @key="item">
                        <MudText>@item.Name</MudText>
                        <MudIconButton @onclick="() => RemoveVar(item)" Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Variant="Variant.Text" Size="Size.Large" />
                    </MudStack>
                }
            </MudPaper>
            <MudPaper class="mt-2">

                <div class="d-flex justify-center">
                    <MudCheckBox @bind-Value="currentMatch.Word" Label="@localizationService.GetString("Word")" />
                </div>
            </MudPaper>
            <MudExpansionPanels Elevation="0" class="mt-2">
                <MudExpansionPanel Text="@localizationService.GetString("Templates")" MaxHeight="1000">
                    <MudStack class="mt-1" Justify="@Justify.SpaceBetween" Row="true">
                        <MudText>@localizationService.GetString("DateToday")</MudText>
                        <MudButton @onclick="() => AddPreBuiltVar(0)" Color="Color.Primary" Variant="Variant.Outlined">@localizationService.GetString("AddVariable")</MudButton>
                    </MudStack>
                    <MudStack class="mt-1" Justify="@Justify.SpaceBetween" Row="true">
                        <MudText>@localizationService.GetString("DateYesterday")</MudText>
                        <MudButton @onclick="() => AddPreBuiltVar(1)" Color="Color.Primary" Variant="Variant.Outlined">@localizationService.GetString("AddVariable")</MudButton>
                    </MudStack>
                    <MudStack class="mt-1" Justify="@Justify.SpaceBetween" Row="true">
                        <MudText>@localizationService.GetString("DateTomorrow")</MudText>
                        <MudButton @onclick="() => AddPreBuiltVar(2)" Color="Color.Primary" Variant="Variant.Outlined">@localizationService.GetString("AddVariable")</MudButton>
                    </MudStack>
                    <MudStack class="mt-1" Justify="@Justify.SpaceBetween" Row="true">
                        <MudText>@localizationService.GetString("TimeNow")</MudText>
                        <MudButton @onclick="() => AddPreBuiltVar(3)" Color="Color.Primary" Variant="Variant.Outlined">@localizationService.GetString("AddVariable")</MudButton>
                    </MudStack>
                    <MudStack class="mt-1" Justify="@Justify.SpaceBetween" Row="true">
                        <MudText>@localizationService.GetString("AddSelectionCursor")</MudText>
                        <MudButton @onclick="() => AddPreBuiltVar(4)" Color="Color.Primary" Variant="Variant.Outlined">@localizationService.GetString("AddCursor")</MudButton>
                    </MudStack>
                </MudExpansionPanel>
            </MudExpansionPanels>
            <MudExpansionPanels Elevation="0" class="mt-2">
                <MudExpansionPanel Text="@localizationService.GetString("AdvancedOptions")" MaxHeight="1000">
                    <MudTextField @bind-Value="currentVar.Name" T="string" Label="@localizationService.GetString("VariableName")" />
                    <MudTextField @bind-Value="currentVar.Type" T="string" Label="@localizationService.GetString("VariableType")" />
                    <MudExpansionPanels Elevation="0">
                        <MudExpansionPanel class="mt-1" Text="@localizationService.GetString("Params")" MaxHeight="1000">
                            <MudTextField @bind-Value="currentVar.Params.Format" T="string" Label="@localizationService.GetString("Format")" />
                            <MudTextField @bind-Value="currentVar.Params.Echo" T="string" Label="@localizationService.GetString("Echo")" />
                            <MudTextField @bind-Value="currentVar.Params.Offset" T="long" Label="@localizationService.GetString("Offset")" />
                        </MudExpansionPanel>
                    </MudExpansionPanels>
                    <div class="d-flex justify-center">
                        <MudButton @onclick="AddCurrentVar" Color="Color.Primary" Variant="Variant.Outlined">@localizationService.GetString("AddVariable")</MudButton>
                    </div>
                </MudExpansionPanel>
            </MudExpansionPanels>
            <MudDivider class="mt-2" />
            @if (dict is not null)
            {
                @foreach (var item in dict.Take(dict.Count < lazyLoadIndex ? dict.Count : lazyLoadIndex))
                {
                    <MatchCard Item="item" OnEdit="() => EditItem(item)" OnDelete="async () => await RemoveItemAsync(item.Value)" @key="item.Key" />
                }
                @if (dict.Count > lazyLoadIndex)
                {
                    <div class="d-flex justify-center mt-3">
                        <MudButton @onclick="AdjustLazyLoad" Color="Color.Primary" Variant="Variant.Filled">
                            @localizationService.GetString("LoadMore")
                        </MudButton>
                    </div>
                }

            }
        }
    </MudTabPanel>
    <MudTabPanel Text="@localizationService.GetString("Tools")">
        <TextTools CanTextExpand="canTextExpand" />
    </MudTabPanel>
</MudTabs>

@code {
    bool canTextExpand = false;
    Match currentMatch = new() { Replace = "On my way", Trigger = "t:omw", Vars = new() { } };
    private Dictionary<string, Match> dict;
    private List<Var> globalVars = new();
    private Var currentVar = new() { Params = new() };
    private int lazyLoadIndex = 100;
    private bool showWelcome = !Preferences.Get("welcomed", false);
#if ANDROID
    private SafObserver _safObserver;
    private WebDavPollingService _webDavPollingService;
    private System.Threading.Timer _gitPollingTimer;
#endif
    private string editingKey = null;
    private bool _syncing = false;
    private bool _saving = false;

    private void DismissWelcome()
    {
        showWelcome = false;
        Preferences.Set("welcomed", true);
    }



    private void AddPreBuiltVar(int i)
    {
        switch (i)
        {
            case 0:
                currentMatch.Vars.Add(new()
                    {
                        Name = "datenow",
                        Type = "date",
                        Params = new()
                        {
                            Format = Utils.GetTheRealFormat("dd/MM/yyyy")
                        }
                    });
                currentMatch.Replace += " {{datenow}}";
                break;
            case 1:
                currentMatch.Vars.Add(new()
                    {
                        Name = "yesterday",
                        Type = "date",
                        Params = new()
                        {
                            Format = Utils.GetTheRealFormat("dd/MM/yyyy"),
                            Offset = -86400
                        }
                    });
                currentMatch.Replace += " {{yesterday}}";
                break;
            case 2:
                currentMatch.Vars.Add(new()
                    {
                        Name = "tommorow",
                        Type = "date",
                        Params = new()
                        {
                            Format = Utils.GetTheRealFormat("dd/MM/yyyy"),
                            Offset = 86400
                        }
                    });
                currentMatch.Replace += " {{tommorow}}";
                break;
            case 3:
                currentMatch.Vars.Add(new()
                    {
                        Name = "time",
                        Type = "date",
                        Params = new()
                        {
                            Format = Utils.GetTheRealFormat("HH:mm"),
                        }
                    });
                currentMatch.Replace += " {{time}}";
                break;
            case 4:
                currentMatch.Replace += " $|$";
                break;

        }
    }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        localizationService.OnLanguageChanged += OnLanguageChanged;
        SyncManager.SyncCompleted += OnSyncCompleted;
        WeakReferenceMessenger.Default.Register<ConfigChangedMessage>(this, (r, m) =>
        {
            InvokeAsync(() =>
            {
#if ANDROID
                StopObservers();
                StartSafObserver();
#endif
            });
        });
        canTextExpand = acService.IsActivated();
        if (File.Exists(AppSettings.OldDictPath))
        {
            try
            {
                var stream = File.OpenRead(AppSettings.OldDictPath);
                dict = JsonSerializer.Deserialize<Dictionary<string, Match>>(stream);
                if (canTextExpand)
                {
                    foreach (var item in dict)
                    {
                        SendMessage("Add", item.Value);
                    }
                }
                await stream.DisposeAsync();
                var backupFn = AppSettings.DictPath + ".oldbackup";
                File.Copy(AppSettings.OldDictPath, backupFn);
                await SaveDictAsync();
                if (File.Exists(backupFn))
                {
                    File.Delete(AppSettings.OldDictPath);
                    await dialogService.DisplayConfirmAsync(localizationService.GetString("MigratedSuccessfully"), localizationService.GetString("MigratedSuccessfullyMessage"));
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add(string.Format(localizationService.GetString("MigrationFailed"), ex.Message), Severity.Error);
            }
        }
        if (dict is null && File.Exists(AppSettings.DictPath))
        {
            try
            {
                using var stream = File.OpenRead(AppSettings.DictPath);
                dict = JsonSerializer.Deserialize<Dictionary<string, Match>>(stream);
                if (canTextExpand)
                {
                    foreach (var item in dict)
                    {
                        SendMessage("Add", item.Value);
                    }
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add(string.Format(localizationService.GetString("DictLoadFailed"), ex.Message), Severity.Error);
                dict = new();
            }
        }
        else if (dict is null)
            dict = new();
        if (File.Exists(AppSettings.GlobalVarsPath))
        {
            using var stream = File.OpenRead(AppSettings.GlobalVarsPath);
            globalVars = JsonSerializer.Deserialize<List<Var>>(stream);
            if (canTextExpand)
            {
                WeakReferenceMessenger.Default.Send(new AcGlobalsMessage(globalVars));
            }
        }

#if ANDROID
        StartSafObserver();
#endif
    }
    private async Task ImportAsync()
    {
        try
        {
            if (await dialogService.DisplayConfirmAsync(localizationService.GetString("Warning"), localizationService.GetString("ImportWarningMessage"), localizationService.GetString("Proceed"), localizationService.GetString("Nevermind")))
            {
                int skips = 0;
                var skipDetails = new List<string>();
                var importMode = await dialogService.DisplayConfirmAsync(
                    localizationService.GetString("ImportMode"),
                    localizationService.GetString("ImportModeDesc"),
                    localizationService.GetString("SingleFile"), localizationService.GetString("YmlFolder"));

                if (importMode)
                {
                    DictWrapper localDict;
                    string baseDir = null;
                    if (await dialogService.DisplayConfirmAsync(localizationService.GetString("ChooseFormat"), localizationService.GetString("SelectYmlIfEspansoConfigFull"), "Json", "Yml"))
                    {
                        var result = await FilePicker.PickAsync(new PickOptions
                            {
                                PickerTitle = localizationService.GetString("PickAConfigJsonFile")
                            });
                        if (result is null) return;
                        using var strm = await result.OpenReadAsync();
                        localDict = await JsonSerializer.DeserializeAsync<DictWrapper>(strm);
                    }
                    else
                    {
                        var result = await FilePicker.PickAsync(new PickOptions
                            {
                                PickerTitle = localizationService.GetString("PickAConfigYmlFile")
                            });
                        if (result is null) return;
                        using var strm = await result.OpenReadAsync();
                        var deserializer = new DeserializerBuilder()
                            .WithNamingConvention(UnderscoredNamingConvention.Instance).IgnoreUnmatchedProperties()
                            .Build();
                        using TextReader tr = new StreamReader(strm);
                        localDict = deserializer.Deserialize<DictWrapper>(tr);
                        baseDir = Path.GetDirectoryName(result?.FullPath);
                    }
                    ProcessImport(localDict, baseDir, ref skips, skipDetails, isRoot: true);
                    if (localDict.Global_vars is not null)
                    {
                        var existingNames = globalVars.Select(v => v.Name).ToHashSet();
                        foreach (var gv in localDict.Global_vars)
                        {
                            if (!existingNames.Contains(gv.Name))
                            {
                                globalVars.Add(gv);
                                existingNames.Add(gv.Name);
                            }
                        }
                        var str = JsonSerializer.Serialize(globalVars);
                        await File.WriteAllTextAsync(AppSettings.GlobalVarsPath, str);
                        WeakReferenceMessenger.Default.Send(new AcGlobalsMessage(globalVars));
                    }
                }
                else
                {
                    var result = await FilePicker.PickAsync(new PickOptions
                    {
                        PickerTitle = localizationService.GetString("PickYmlInMatchFolder")
                    });
                    if (result?.FullPath is null)
                        return;
                    var folderPath = Path.GetDirectoryName(result.FullPath);
                    if (string.IsNullOrEmpty(folderPath) || !Directory.Exists(folderPath))
                    {
                        Snackbar.Add(localizationService.GetString("CannotAccessFolder"), Severity.Error);
                        return;
                    }

                    var importedDict = await YamlWorkspace.ReadFromFolderAsync(folderPath);
                    foreach (var item in importedDict)
                    {
                        if (item.Value.Vars is not null)
                        {
                            bool notSupported = item.Value.Replace is null;
                            foreach (var x in item.Value.Vars)
                            {
                                if (x.Type is not null && !AppSettings.SupportedList.Contains(x.Type))
                                {
                                    skips++;
                                    notSupported = true;
                                    skipDetails.Add($"{item.Key ?? "?"}: unsupported var type '{x.Type}'");
                                    break;
                                }
                                else if (x.Type == "date")
                                {
                                    try { x.Params.Format = Utils.GetTheRealFormat(x.Params.Format); }
                                    catch (Exception) { }
                                }
                            }
                            if (notSupported) continue;
                        }
                        if (item.Value.Triggers is not null && item.Value.Triggers.Count > 0)
                        {
                            foreach (var t in item.Value.Triggers)
                            {
                                var clone = new Match(item.Value) { Trigger = t };
                                dict[t] = clone;
                                SendMessage("Add", clone);
                            }
                        }
                        else
                        {
                            dict[item.Key] = item.Value;
                            SendMessage("Add", item.Value);
                        }
                    }
                }

                await SaveDictAsync();
                var msg = string.Format(localizationService.GetString("ImportSuccessfulMessage"), skips);
                if (skipDetails.Count > 0)
                    msg += "\n" + string.Join("\n", skipDetails);
                await dialogService.DisplayConfirmAsync(localizationService.GetString("ImportSuccessful"), msg);
            }
        }
        catch (Exception e)
        {
            await dialogService.DisplayConfirmAsync(localizationService.GetString("Error"), localizationService.GetString("RestartAppToEnsureSync") + e.Message);
        }
    }

    private void ProcessImport(DictWrapper localDict, string baseDir, ref int skips, List<string> skipDetails, bool isRoot, int depth = 0)
    {
        if (depth > 5 || localDict?.Matches is null)
            return;

        foreach (var item in localDict.Matches)
        {
            if (item.Vars is not null)
            {
                bool notSupported = item.Replace is null;
                string skipReason = null;
                foreach (var x in item.Vars)
                {
                    if (x.Type is not null)
                    {
                        if (!AppSettings.SupportedList.Contains(x.Type))
                        {
                            skips++;
                            notSupported = true;
                            skipReason = $"{item.Trigger ?? "?"}: unsupported var type '{x.Type}'";
                            break;
                        }
                        else if (x.Type == "date")
                        {
                            try
                            {
                                x.Params.Format = Utils.GetTheRealFormat(x.Params.Format);
                            }
                            catch (Exception)
                            {
                                throw new Exception(localizationService.GetString("DateExtensionParameterFormatsError"));
                            }
                        }
                    }
                }
                if (notSupported)
                {
                    if (skipReason is not null)
                        skipDetails.Add(skipReason);
                    continue;
                }
            }
            // Expand triggers (multi-trigger) into separate entries
            if (item.Triggers is not null && item.Triggers.Count > 0)
            {
                foreach (var t in item.Triggers)
                {
                    var clone = new Match(item) { Trigger = t };
                    dict[t] = clone;
                    SendMessage("Add", clone);
                }
            }
            else if (!string.IsNullOrEmpty(item.Trigger))
            {
                dict[item.Trigger] = item;
                SendMessage("Add", item);
            }
            else if (!string.IsNullOrEmpty(item.Regex))
            {
                dict[$"__regex_{item.Regex}"] = item;
                SendMessage("Add", item);
            }
        }

        // Recursively resolve imports (YAML only, relative to baseDir)
        if (isRoot && localDict.Imports is not null && baseDir is not null)
        {
            foreach (var importPath in localDict.Imports)
            {
                try
                {
                    var fullPath = Path.Combine(baseDir, importPath);
                    if (File.Exists(fullPath))
                    {
                        var yamlText = File.ReadAllText(fullPath);
                        var deserializer = new DeserializerBuilder()
                            .WithNamingConvention(UnderscoredNamingConvention.Instance).IgnoreUnmatchedProperties()
                            .Build();
                        var imported = deserializer.Deserialize<DictWrapper>(yamlText);
                        ProcessImport(imported, Path.GetDirectoryName(fullPath), ref skips, skipDetails, isRoot: false, depth: depth + 1);
                    }
                }
                catch (Exception) { }
            }
        }
    }
    private async Task ExportAsync()
    {
        try
        {
            if (dict.Count == 0)
            {
                Snackbar.Add(localizationService.GetString("EmptyDictExport"), Severity.Warning);
            }
            string text = null;
            string name = null;
            DictWrapper dictWrapper = new DictWrapper()
                {
                    Matches = new List<Match>(),
                    Global_vars = globalVars
                };
            foreach (var item in dict)
            {
                var exportMatch = new Match(item.Value);
                if (exportMatch.Replace is not null)
                {
                    exportMatch.Replace = exportMatch.Replace.Replace("\\n", Environment.NewLine);
                    if (exportMatch.Vars is not null)
                    {
                        foreach (var x in exportMatch.Vars)
                        {
                            if (x.Type == "date")
                            {
                                x.Params.Format = Utils.GetOriginalFormat(x.Params.Format);
                            }
                        }
                    }

                }
                dictWrapper.Matches.Add(exportMatch);
            }
            if (await dialogService.DisplayConfirmAsync(localizationService.GetString("ChooseFormat"), localizationService.GetString("SelectYmlIfEspansoConfig"), "Json", "Yml"))
            {
                text = JsonSerializer.Serialize(dictWrapper);
                name = "ttconfig.json";
            }
            else
            {
                var serializer = new SerializerBuilder()
                    .WithNamingConvention(UnderscoredNamingConvention.Instance)
                    .Build();
                text = serializer.Serialize(dictWrapper);
                text = "# yaml-language-server: $schema=https://raw.githubusercontent.com/espanso/espanso/master/schemas/match.schema.json\n" + text;
                name = "ttconfig.yml";
            }
            if (OperatingSystem.IsAndroidVersionAtLeast(33))
            {
                //string file = Path.Combine(FileSystem.CacheDirectory, name);
                //File.WriteAllText(file, text);
                //await Share.Default.RequestAsync(new ShareFileRequest
                //    {
                //        Title = "Share config file",
                //        File = new ShareFile(file)
                //    });
                acService.RequestPermission();
            }
            using MemoryStream strm = new(Encoding.UTF8.GetBytes(text));
            var fs = await fileSaver.SaveAsync(name, strm, CancellationToken.None);
            fs.EnsureSuccess();
            Snackbar.Add(localizationService.GetString("ExportSuccessfulMessage"), Severity.Success);
        }
        catch (Exception e)
        {
            await dialogService.DisplayConfirmAsync(localizationService.GetString("Error"), localizationService.GetString("RestartAppToEnsureSync") + e.Message);
        }
    }
    private void AddCurrentVar()
    {
        Var copy = new(currentVar) { Params = new(currentVar.Params) };
        if (!string.IsNullOrEmpty(copy.Params.Format))
        {
            copy.Params.Format = Utils.GetTheRealFormat(copy.Params.Format);
        }
        currentMatch.Vars.Add(copy);
    }
    private void RemoveVar(Var item)
    {
        currentMatch.Vars.Remove(item);
    }
    private async Task AddItemAsync()
    {
        try
        {
            var copy = new Match(currentMatch); // Otherwise the dic just uses the same memory LOL!
            if (!(string.IsNullOrEmpty(copy.Trigger) || string.IsNullOrEmpty(copy.Replace)))
            {
                if (editingKey is not null && editingKey != copy.Trigger && dict.ContainsKey(editingKey))
                {
                    var oldItem = dict[editingKey];
                    dict.Remove(editingKey);
                    SendMessage("Remove", oldItem);
                }
                if (dict.ContainsKey(copy.Trigger) && (editingKey is null || editingKey != copy.Trigger))
                {
                    var overwrite = await dialogService.DisplayConfirmAsync(
                        localizationService.GetString("DuplicateTrigger"),
                        string.Format(localizationService.GetString("DuplicateTrigger"), copy.Trigger));
                    if (!overwrite)
                        return;
                }
                dict[copy.Trigger] = new(copy); // need another copy :(
                copy.Replace = copy.Replace.Replace("\\n", Environment.NewLine);
                SendMessage("Add", copy);
                editingKey = null;
                currentMatch = new() { Replace = "", Trigger = "", Vars = new() };
            }
            else
            {
                await dialogService.DisplayConfirmAsync(localizationService.GetString("EmptyValues"), localizationService.GetString("FillOutRequiredParameters"));
            }
        }
        catch (Exception e)
        {
            await dialogService.DisplayConfirmAsync(localizationService.GetString("Error"), localizationService.GetString("RestartAppToEnsureSync") + e.Message);
        }
    }
    private async Task RemoveItemAsync(Match item)
    {
        try
        {
            if (dict.Remove(item.Trigger, out var _))
            {
                SendMessage("Remove", item);
                Snackbar.Add(localizationService.GetString("DeletedItem"), Severity.Success);
            }
            else
            {
                await dialogService.DisplayConfirmAsync(localizationService.GetString("CouldNotDeleteItem"), localizationService.GetString("DeleteItemBugMessage") + item.Trigger);
            }
        }
        catch (Exception e)
        {
            await dialogService.DisplayConfirmAsync(localizationService.GetString("Error"), localizationService.GetString("RestartAppToEnsureSync") + e.Message);
        }
    }
    private async Task SaveDictAsync(bool silent = false)
    {
        if (_saving) return;
        _saving = true;
        try
        {
            foreach (var item in dict)
            {
                if (item.Value.Replace is not null)
                {
                    item.Value.Replace = item.Value.Replace.Replace("\\n", Environment.NewLine);
                }
            }
            var str = JsonSerializer.Serialize(dict);
            await File.WriteAllTextAsync(AppSettings.DictPath, str);
            if (!silent)
                Snackbar.Add(localizationService.GetString("SaveSuccessfulMessage"), Severity.Success);

            var config = SyncManager.GetConfig();
            if (config.Method != SyncMethod.None && !string.IsNullOrEmpty(config.SyncUri))
            {
                _ = SyncManager.PushAsync(dict, globalVars);
            }
        }
        catch (Exception e)
        {
            await dialogService.DisplayConfirmAsync(localizationService.GetString("Error"), e.Message);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task SyncNowAsync()
    {
        if (!await SyncManager.SyncLock.WaitAsync(0))
            return;
        _syncing = true;
        try
        {
            var config = SyncManager.GetConfig();
            if (config.Method == SyncMethod.None)
            {
                Snackbar.Add(localizationService.GetString("SyncNotConfigured"), Severity.Info);
                NavigationManager.NavigateTo("/syncsetup");
                return;
            }
            if (config.Method == SyncMethod.Manual)
            {
                Snackbar.Add(localizationService.GetString("ManualSyncHint"), Severity.Info);
                return;
            }

            await SaveDictAsync(silent: true);
            var result = await SyncManager.SyncAsync(dict, globalVars);
            if (result.Success)
            {
                if (result.HasRemoteChanges)
                {
                    foreach (var kv in dict)
                    {
                        SendMessage("Update", kv.Value);
                    }
                    if (globalVars != null)
                    {
                        var gvStr = JsonSerializer.Serialize(globalVars);
                        await File.WriteAllTextAsync(AppSettings.GlobalVarsPath, gvStr);
                        WeakReferenceMessenger.Default.Send(new AcGlobalsMessage(globalVars));
                    }
                    await SaveDictAsync(silent: true);
                    AdjustLazyLoad();
                    StateHasChanged();
                }

                if (SyncManager.LastMergeWarnings?.Count > 0)
                {
                    foreach (var w in SyncManager.LastMergeWarnings)
                        Snackbar.Add(w, Severity.Warning);
                }

                if (result.Conflicts > 0)
                {
                    Snackbar.Add(string.Format(localizationService.GetString("SyncedFiles"), result.FilesSynced) + ", " + string.Format(localizationService.GetString("ConflictsDetected"), result.Conflicts), Severity.Warning, config =>
                    {
                        config.Action = localizationService.GetString("Resolve");
                        config.ActionColor = Color.Warning;
                        config.OnClick = snackbar =>
                        {
                            NavigationManager.NavigateTo("/conflicts");
                        };
                    });
                }
                else
                {
                    Snackbar.Add(string.Format(localizationService.GetString("SyncedFiles"), result.FilesSynced), Severity.Success);
                }
            }
            else
            {
                Snackbar.Add(string.Format(localizationService.GetString("SyncFailed"), result.ErrorMessage), Severity.Error);
            }
        }
        catch (Exception e)
        {
            Snackbar.Add(string.Format(localizationService.GetString("SyncError"), e.Message), Severity.Error);
        }
        finally
        {
            _syncing = false;
            SyncManager.SyncLock.Release();
        }
    }

    private void OnSyncCompleted(Services.SyncStatus status, SyncResult result)
    {
        InvokeAsync(async () =>
        {
            if (result?.HasRemoteChanges == true)
            {
                if (File.Exists(AppSettings.DictPath))
                {
                    using var stream = File.OpenRead(AppSettings.DictPath);
                    dict = JsonSerializer.Deserialize<Dictionary<string, Match>>(stream);
                    foreach (var kv in dict)
                    {
                        SendMessage("Update", kv.Value);
                    }
                }
                if (File.Exists(AppSettings.GlobalVarsPath))
                {
                    var gvJson = await File.ReadAllTextAsync(AppSettings.GlobalVarsPath);
                    var gv = JsonSerializer.Deserialize<List<Var>>(gvJson);
                    if (gv != null)
                    {
                        globalVars = gv;
                        WeakReferenceMessenger.Default.Send(new AcGlobalsMessage(globalVars));
                    }
                }
                AdjustLazyLoad();
                StateHasChanged();
            }
        });
    }

    private void SendMessage(string cmd, Match value)
    {
        WeakReferenceMessenger.Default.Send(new AcServiceMessage((cmd, value)));
    }
    private async Task OpenSettings()
    {
        try
        {
            if (await dialogService.DisplayConfirmAsync(localizationService.GetString("NeedConsent"), localizationService.GetString("GiveConsentMessage"), localizationService.GetString("IGiveConsent"), localizationService.GetString("Nevermind")))
            {
                acService.OpenSettings();
                await ForceQuit();
            }
        }
        catch (Exception e)
        {
            await dialogService.DisplayConfirmAsync(localizationService.GetString("Error"), e.Message);
        }
    }
    private async Task ForceQuit()
    {
        var confirm = await dialogService.DisplayConfirmAsync(
            localizationService.GetString("ForceQuitApp"),
            localizationService.GetString("ConfirmForceQuit"));
        if (!confirm) return;
        WeakReferenceMessenger.Default.Send(new AcServiceMessage(("Quit", null)));
        Application.Current.Quit();
    }

    private void EditItem(KeyValuePair<string, Match> item)
    {
        editingKey = item.Key;
        currentMatch.Trigger = item.Value.Trigger;
        currentMatch.Replace = item.Value.Replace;
        if (item.Value.Vars is not null)
        {
            currentMatch.Vars = item.Value.Vars.Select(v => new Var(v)).ToList();
        }
        currentVar = new() { Params = new() };
        StateHasChanged();
    }

    private void CancelEdit()
    {
        editingKey = null;
        currentMatch = new() { Replace = "", Trigger = "", Vars = new() };
        StateHasChanged();
    }
    private void AdjustLazyLoad()
    {
        var diff = dict.Count - lazyLoadIndex;
        if (diff > 100)
        {
            lazyLoadIndex += 100;
        }
        else
        {
            lazyLoadIndex += diff;
        }
    }

    private void OnLanguageChanged()
    {
        StateHasChanged();
    }

#if ANDROID
    private void StartSafObserver()
    {
        try
        {
            var config = SyncManager.GetConfig();
            if (config.Method == SyncMethod.None || string.IsNullOrEmpty(config.SyncUri))
                return;

            if (config.SyncUri.StartsWith("content://"))
            {
                var safManager = new SafManager(Android.App.Application.Context);
                _safObserver = new SafObserver(safManager, SyncManager, config.SyncUri, config.ForegroundPollIntervalSec);
                _safObserver.OnRemoteChanged += OnSafRemoteChanged;
                _safObserver.Start();
            }
            else if (config.Method == SyncMethod.WebDAV)
            {
                _webDavPollingService = new WebDavPollingService(SyncManager, config.ForegroundPollIntervalSec);
                _webDavPollingService.OnRemoteChanged += OnSafRemoteChanged;
                _webDavPollingService.Start();
            }
            else if (config.Method == SyncMethod.Git)
            {
                _gitPollingTimer = new System.Threading.Timer(
                    async _ => await InvokeAsync(async () =>
                    {
                        try
                        {
                            if (await SyncManager.GitHasRemoteChangesAsync())
                                await SyncNowAsync();
                        }
                        catch { }
                    }),
                    null, TimeSpan.FromSeconds(config.ForegroundPollIntervalSec), TimeSpan.FromSeconds(config.ForegroundPollIntervalSec));
            }
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"StartSafObserver failed: {ex.Message}");
        }
    }

    private async void OnSafRemoteChanged()
    {
        await InvokeAsync(async () =>
        {
            try
            {
                await SyncNowAsync();
            }
            catch { }
        });
    }
#endif

#if ANDROID
    private void StopObservers()
    {
        _safObserver?.Stop();
        _safObserver?.Dispose();
        _safObserver = null;
        _webDavPollingService?.Dispose();
        _webDavPollingService = null;
        _gitPollingTimer?.Dispose();
        _gitPollingTimer = null;
    }
#endif

    public void Dispose()
    {
        localizationService.OnLanguageChanged -= OnLanguageChanged;
        SyncManager.SyncCompleted -= OnSyncCompleted;
        WeakReferenceMessenger.Default.Unregister<ConfigChangedMessage>(this);
#if ANDROID
        StopObservers();
#endif
    }
}

