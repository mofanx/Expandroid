@inject ILocalizationService localizationService
@inject Expandroid.Services.IDialogService dialogService
@inject ISnackbar Snackbar

<MudStack Row="true" Justify="Justify.FlexEnd" Class="mb-2">
    <MudIconButton Icon="@Icons.Material.Filled.SwapVert" OnClick="SwapText" Size="Size.Small" Title="@localizationService.GetString("Swap")" />
    <MudIconButton Icon="@Icons.Material.Filled.Clear" OnClick="ClearText" Size="Size.Small" Title="@localizationService.GetString("Clear")" />
</MudStack>
<MudTextField T="string" HelperText="@localizationService.GetString("Length")" Counter="textList[0].Length" Label="@localizationService.GetString("Text1")" Variant="Variant.Outlined" @bind-Value="@textList[0]" Lines="3" Class="mb-3" />
<MudTextField T="string" HelperText="@localizationService.GetString("Length")" Counter="textList[1].Length" Label="@localizationService.GetString("Text2")" Variant="Variant.Outlined" @bind-Value="@textList[1]" Lines="3" Class="mb-3" />

<MudExpansionPanels Elevation="0" Outlined="true" Class="mb-3" MultiSelection="false">
    <MudExpansionPanel Text="@localizationService.GetString("Basic")" MaxHeight="1000" Expanded="@(_activeMode == 0)" ExpandedChanged="@(EventCallback.Factory.Create<bool>(this, OnBasicExpandedChanged))">
        <MudStack Spacing="2">
            <MudCheckBox Label="@localizationService.GetString("Compare")" @bind-Value="@compare" Color="Color.Primary" />
            <MudCheckBox Label="@localizationService.GetString("IgnoreCase")" @bind-Value="@ignoreCase" Color="Color.Primary" />
            <MudCheckBox Label="@localizationService.GetString("CompareLength")" @bind-Value="@lengthCompare" Color="Color.Primary" />
            <MudCheckBox Label="@localizationService.GetString("Contains")" @bind-Value="@contains" Color="Color.Primary" />
            <MudCheckBox Label="@localizationService.GetString("Replace")" @bind-Value="@replace" Color="Color.Primary" />
            <MudCheckBox Label="@localizationService.GetString("ToUpper")" @bind-Value="@toUpper" Color="Color.Primary" />
            <MudCheckBox Label="@localizationService.GetString("ToLower")" @bind-Value="@toLower" Color="Color.Primary" />
            @if (contains)
            {
                <MudTextField T="string" Label="@localizationService.GetString("ContainsWhat")" @bind-Value="@containsText" Variant="Variant.Outlined" Dense="true" Lines="2" />
            }
            @if (replace)
            {
                <MudTextField T="string" Label="@localizationService.GetString("Replace")" @bind-Value="@replaceText" Variant="Variant.Outlined" Dense="true" Lines="2" />
                <MudTextField T="string" Label="@localizationService.GetString("ReplaceWith")" @bind-Value="@replaceWithText" Variant="Variant.Outlined" Dense="true" Lines="2" />
            }
        </MudStack>
    </MudExpansionPanel>
    <MudExpansionPanel Text="@localizationService.GetString("DiscordMarkdown")" MaxHeight="1000" Expanded="@(_activeMode == 1)" ExpandedChanged="@(EventCallback.Factory.Create<bool>(this, OnDiscordExpandedChanged))">
        <MudStack Spacing="2">
            <MudCheckBox Label="@localizationService.GetString("Bold")" @bind-Value="@makeBold" Color="Color.Primary" />
            <MudCheckBox Label="@localizationService.GetString("Italic")" @bind-Value="@makeItalic" Color="Color.Primary" />
            <MudCheckBox Label="@localizationService.GetString("Underline")" @bind-Value="@makeUnderline" Color="Color.Primary" />
            <MudCheckBox Label="@localizationService.GetString("Strikethrough")" @bind-Value="@makeStrike" Color="Color.Primary" />
            <MudCheckBox Label="@localizationService.GetString("Spoilers")" @bind-Value="@makeSpoiler" Color="Color.Primary" />
            <MudCheckBox Label="@localizationService.GetString("CodeBlock")" @bind-Value="@makeCode" Color="Color.Primary" />
            <MudCheckBox Label="@localizationService.GetString("Quote")" @bind-Value="@makeQuote" Color="Color.Primary" />
            <MudCheckBox Label="@localizationService.GetString("AddTimestamp")" @bind-Value="@addTimeStamp" Color="Color.Primary" />
            @if (addTimeStamp)
            {
                <MudDatePicker Label="@localizationService.GetString("PickADate")" @bind-Date="date" Dense="true" />
                <MudTimePicker Label="@localizationService.GetString("PickATime")" @bind-Time="timeSpan" Dense="true" />
            }
        </MudStack>
    </MudExpansionPanel>
</MudExpansionPanels>

<MudNumericField Label="@localizationService.GetString("ProcessOnTextNumber")" Min="1" Max="2" @bind-Value="@index" Dense="true" Variant="Variant.Outlined" Class="mb-3" />

<div class="d-flex justify-center mb-3">
    <MudButtonGroup Variant="Variant.Outlined" Color="Color.Primary">
        <MudButton Disabled="@processing" OnClick="Process" StartIcon="@Icons.Material.Filled.PlayArrow">
            @if (processing)
            {
                <MudProgressCircular Class="ms-n1 mr-2" Size="Size.Small" Indeterminate="true" />
                <MudText Class="ms-2">@localizationService.GetString("Processing")</MudText>
            }
            else
            {
                <MudText>@localizationService.GetString("Process")</MudText>
            }
        </MudButton>
        <MudButton OnClick="async () => await CopyTextAsync(1)" StartIcon="@Icons.Material.Filled.ContentCopy">@localizationService.GetString("CopyText1")</MudButton>
        <MudButton OnClick="async () => await CopyTextAsync(2)" StartIcon="@Icons.Material.Filled.ContentCopy">@localizationService.GetString("CopyText2")</MudButton>
    </MudButtonGroup>
</div>

<MudDivider Class="mb-3" />
<MudCard Elevation="1">
    <MudCardContent>
        <MudText Typo="Typo.h6" Class="mb-2">@localizationService.GetString("Results")</MudText>
        <MudText Typo="Typo.body2" Color="Color.Default" Class="mb-2" Style="font-family: monospace;">@localizationService.GetString("ProcessCount") @processCount</MudText>
        <MudStack Spacing="1">
            <MudStack Row="true" Align="Align.Center" Spacing="2">
                <MudIcon Icon="@(compareResult ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)" Color="@(compareResult ? Color.Success : Color.Error)" Size="Size.Small" />
                <MudText Typo="Typo.body2">@localizationService.GetString("IsTextEqual")</MudText>
            </MudStack>
            <MudStack Row="true" Align="Align.Center" Spacing="2">
                <MudIcon Icon="@(containsResult ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)" Color="@(containsResult ? Color.Success : Color.Error)" Size="Size.Small" />
                <MudText Typo="Typo.body2">@localizationService.GetString("ContainsTheWordSpecified")</MudText>
            </MudStack>
            <MudStack Row="true" Align="Align.Center" Spacing="2">
                <MudIcon Icon="@(lengthCompareResult ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)" Color="@(lengthCompareResult ? Color.Success : Color.Error)" Size="Size.Small" />
                <MudText Typo="Typo.body2">@localizationService.GetString("IsLengthEqual")</MudText>
            </MudStack>
        </MudStack>
    </MudCardContent>
</MudCard>

@code {
    [Parameter] public bool CanTextExpand { get; set; }

    private List<string> textList = new() { "", "" };
    private bool compare = true;
    private bool ignoreCase = false;
    private bool processing = false;
    private bool compareResult = false;
    private bool lengthCompare = false;
    private bool lengthCompareResult = false;
    private bool contains = false;
    private string containsText = string.Empty;
    private bool containsResult = false;
    private int index = 1;
    private bool replace = false;
    private string replaceText = string.Empty;
    private string replaceWithText = string.Empty;
    private bool toUpper = false;
    private bool toLower = false;
    private ulong processCount = 0;
    private int _activeMode = 0;

    private void OnBasicExpandedChanged(bool expanded)
    {
        if (expanded) _activeMode = 0;
    }

    private void OnDiscordExpandedChanged(bool expanded)
    {
        if (expanded) _activeMode = 1;
    }

    private bool makeBold = true;
    private bool makeItalic = false;
    private bool makeStrike = false;
    private bool makeCode = false;
    private bool makeQuote = false;
    private bool makeUnderline = false;
    private bool makeSpoiler = false;
    private bool addTimeStamp = false;
    private DateTime? date;
    private TimeSpan? timeSpan;

    private async Task Process()
    {
        processing = true;
        processCount++;
        try
        {
            if (_activeMode == 0)
            {
                if (compare)
                {
                    compareResult = textList[0].Equals(textList[1], ignoreCase ? StringComparison.OrdinalIgnoreCase : StringComparison.Ordinal);
                }
                if (lengthCompare)
                {
                    lengthCompareResult = textList[0].Length == textList[1].Length;
                }
                if (contains)
                {
                    containsResult = textList[index - 1].Contains(containsText, ignoreCase ? StringComparison.OrdinalIgnoreCase : StringComparison.Ordinal);
                }
                if (replace)
                {
                    textList[index - 1] = textList[index - 1].Replace(replaceText, replaceWithText, ignoreCase ? StringComparison.OrdinalIgnoreCase : StringComparison.Ordinal);
                }
                if (toUpper)
                {
                    textList[index - 1] = textList[index - 1].ToUpper();
                }
                if (toLower)
                {
                    textList[index - 1] = textList[index - 1].ToLower();
                }
            }
            else
            {
                var text = textList[index - 1];
                if (makeBold && !text.StartsWith("**") && !text.EndsWith("**"))
                {
                    text = "**" + text + "**";
                }
                if (makeItalic && !text.StartsWith("*") && !text.EndsWith("*"))
                {
                    text = "*" + text + "*";
                }
                if (makeUnderline && !text.StartsWith("__") && !text.EndsWith("__"))
                {
                    text = "__" + text + "__";
                }
                if (makeStrike && !text.StartsWith("~~") && !text.EndsWith("~~"))
                {
                    text = "~~" + text + "~~";
                }
                if (makeSpoiler && !text.StartsWith("||") && !text.EndsWith("||"))
                {
                    text = "||" + text + "||";
                }
                if (makeCode && !text.StartsWith("```") && !text.EndsWith("```"))
                {
                    text = "```" + text + "```";
                }
                if (makeQuote && !text.StartsWith(">>>"))
                {
                    text = ">>>" + text;
                }
                if (addTimeStamp)
                {
                    if (date is null || timeSpan is null)
                    {
                        await dialogService.DisplayConfirmAsync(localizationService.GetString("Error"), localizationService.GetString("TimestampNotSelected"));
                        processing = false;
                        return;
                    }
                    text += " <t:" + ((DateTimeOffset)(date + timeSpan)).ToUnixTimeSeconds() + ":f>";
                }
                textList[index - 1] = text;
            }
        }
        catch (Exception e)
        {
            await dialogService.DisplayConfirmAsync(localizationService.GetString("Error"), e.Message);
        }
        processing = false;
    }

    private async Task CopyTextAsync(int n)
    {
        await Clipboard.Default.SetTextAsync(textList[n - 1]);
        Snackbar.Add(localizationService.GetString("CopiedTextMessage"), Severity.Success);
    }

    private void SwapText()
    {
        (textList[0], textList[1]) = (textList[1], textList[0]);
    }

    private void ClearText()
    {
        textList[0] = "";
        textList[1] = "";
    }
}
