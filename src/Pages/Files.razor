@page "/files"
@page "/files/{FileName}"
@using EspansoGo.Models
@using EspansoGo.Services
@using System.Text.Json
@using System.Linq
@inject ILocalizationService LocalizationService
@inject EspansoGo.Services.IDialogService DialogService
@inject MudBlazor.IDialogService MudDialogService
@inject ISnackbar Snackbar
@inject SyncManager SyncManager
@inject YamlWorkspace YamlWorkspace
@inject Microsoft.AspNetCore.Components.NavigationManager NavigationManager
@implements IDisposable

@if (string.IsNullOrEmpty(FileName))
{
    <MudPaper Elevation="0" Class="page-container">
        <MudStack Spacing="2">
            <MudStack Row="true" Justify="@Justify.FlexEnd" Align="Align.Center" Class="px-2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateDialog">
                    @LocalizationService.GetString("NewFile")
                </MudButton>
            </MudStack>

            <MudDivider Class="my-2" />

            @if (_loading)
            {
                @for (int i = 0; i < 4; i++)
                {
                    <MudSkeleton Height="56px" Elevation="0" Class="rounded-lg" />
                }
            }
            else if (_fileGroups.Count == 0)
            {
                <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-6">
                    <MudIcon Icon="@Icons.Material.Filled.FolderOpen" Size="Size.Large" Color="Color.Default" />
                    <MudText Typo="Typo.body2" Align="Align.Center" Style="opacity: 0.7;">@LocalizationService.GetString("EmptyFile")</MudText>
                </MudStack>
            }
            else
            {
                <MudList DisablePadding="true">
                    @foreach (var group in _fileGroups)
                    {
                        <MudListItem Clickable="true" OnClick="() => OpenFile(group.Key)" Class="px-4 py-3">
                            <MudStack Row="true" Align="Align.Center" Justify="@Justify.SpaceBetween" Style="width: 100%;">
                                <MudStack Row="true" Align="Align.Center" Spacing="2">
                                    <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" Color="Color.Primary" />
                                    <MudText Typo="Typo.body2">@(group.Key == null ? "base.yml" : group.Key)</MudText>
                                </MudStack>
                                <MudChip Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">
                                    @string.Format(LocalizationService.GetString("MatchesCount"), group.Count())
                                </MudChip>
                            </MudStack>
                        </MudListItem>
                    }
                </MudList>
            }
        </MudStack>
    </MudPaper>
}
else
{
    <MudPaper Elevation="0" Class="page-container">
        <MudStack Spacing="2">
        @if (_yamlEditMode)
        {
            <MudText Typo="Typo.body2" Class="font-weight-medium px-2">@LocalizationService.GetString("YamlEditor")</MudText>
            <MudTextField @bind-Value="_yamlText" Variant="Variant.Outlined" Lines="20" Style="font-family: monospace; font-size: 0.85rem;" Class="px-2" />
            <MudStack Row="true" Spacing="2" Class="px-2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveYamlEdit">@LocalizationService.GetString("Save")</MudButton>
                <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="CancelYamlEdit">@LocalizationService.GetString("Cancel")</MudButton>
            </MudStack>
        }
        else
        {
            <MudTextField @bind-Value="_searchQuery" Label="@LocalizationService.GetString("Search")" Variant="Variant.Outlined" Dense="true" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true" DebounceInterval="300" Class="px-2" />

            @if (_filteredMatches.Count == 0)
            {
                <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-6">
                    <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Color="Color.Default" />
                    <MudText Typo="Typo.body2" Align="Align.Center" Style="opacity: 0.7;">@LocalizationService.GetString("EmptyFile")</MudText>
                </MudStack>
            }
            else
            {
                @foreach (var item in _filteredMatches)
                {
                    <MatchCard Item="item" OnEdit="() => EditMatch(item)" OnDelete="async () => await DeleteMatch(item)" @key="item.Key" />
                }
            }

            <MudStack Row="true" Spacing="2" Class="px-2 pt-2">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit" OnClick="OpenRenameDialog">
                    @LocalizationService.GetString("RenameFile")
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete" OnClick="ConfirmDeleteFile">
                    @LocalizationService.GetString("DeleteFile")
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Info" StartIcon="@Icons.Material.Filled.Code" OnClick="EnterYamlEditMode">
                    @LocalizationService.GetString("YamlEditor")
                </MudButton>
            </MudStack>
        }
        </MudStack>
    </MudPaper>
}

@code {
    [Parameter] public string FileName { get; set; }

    private Dictionary<string, Match> _dict = new();
    private bool _loading = true;
    private string _searchQuery = "";
    private List<Var> _globalVars = new();

    private List<IGrouping<string, KeyValuePair<string, Match>>> _fileGroups = new();
    private List<KeyValuePair<string, Match>> _filteredMatches = new();
    private bool _yamlEditMode = false;
    private string _yamlText = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadDictAsync();
        _loading = false;
        UpdateView();
    }

    protected override void OnParametersSet()
    {
        if (!_loading)
            UpdateView();
    }

    private async Task LoadDictAsync()
    {
        if (File.Exists(AppSettings.DictPath))
        {
            try
            {
                var json = await File.ReadAllTextAsync(AppSettings.DictPath);
                _dict = JsonSerializer.Deserialize<Dictionary<string, Match>>(json);
            }
            catch
            {
                _dict = new();
            }
        }

        if (File.Exists(AppSettings.GlobalVarsPath))
        {
            try
            {
                var gvJson = await File.ReadAllTextAsync(AppSettings.GlobalVarsPath);
                _globalVars = JsonSerializer.Deserialize<List<Var>>(gvJson);
            }
            catch { }
        }
    }

    private void UpdateView()
    {
        if (string.IsNullOrEmpty(FileName))
        {
            _fileGroups = _dict
                .GroupBy(kv => kv.Value.SourceFile)
                .OrderBy(g => g.Key == null ? 1 : 0)
                .ThenBy(g => g.Key)
                .ToList();
        }
        else
        {
            var matches = _dict.Where(kv =>
                (kv.Value.SourceFile == FileName) ||
                (kv.Value.SourceFile == null && FileName == "__uncategorized__"))
                .ToList();

            if (!string.IsNullOrEmpty(_searchQuery))
            {
                matches = matches.Where(kv =>
                    kv.Key.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) ||
                    (kv.Value.Replace?.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) ?? false))
                    .ToList();
            }

            _filteredMatches = matches;
        }
    }

    private void OpenFile(string fileName)
    {
        var route = fileName == null ? "/files/__uncategorized__" : $"/files/{fileName}";
        NavigationManager.NavigateTo(route);
    }

    private void EditMatch(KeyValuePair<string, Match> item)
    {
        NavigationManager.NavigateTo($"/match-editor?edit={Uri.EscapeDataString(item.Key)}");
    }

    private async Task DeleteMatch(KeyValuePair<string, Match> item)
    {
        _dict.Remove(item.Key);
        await SaveDictAsync();
        UpdateView();
        StateHasChanged();
    }

    private async Task OpenCreateDialog()
    {
        var parameters = new DialogParameters
        {
            { "ShowTemplate", true },
            { "SubmitLabel", LocalizationService.GetString("Create") },
        };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall };
        var dialog = MudDialogService.Show<FileNameDialog>(LocalizationService.GetString("NewFile"), parameters, options);
        var result = await dialog.Result;
        if (result.Canceled || result.Data is not (string newName, string template)) return;

        if (string.IsNullOrWhiteSpace(newName)) return;

        if (!newName.EndsWith(".yml") && !newName.EndsWith(".yaml"))
        {
            Snackbar.Add(LocalizationService.GetString("InvalidFileName"), Severity.Error);
            return;
        }

        var existing = _dict.Values.Select(m => m.SourceFile).Where(s => !string.IsNullOrEmpty(s)).ToHashSet();
        if (existing.Contains(newName))
        {
            Snackbar.Add(LocalizationService.GetString("FileAlreadyExists"), Severity.Error);
            return;
        }

        Preferences.Set("last_source_file", newName);

        if (template == LocalizationService.GetString("TemplateBlank") || string.IsNullOrEmpty(template))
        {
            UpdateView();
            StateHasChanged();
            return;
        }

        var seedMatches = GetTemplateMatches(template, newName);
        if (seedMatches.Count > 0)
        {
            foreach (var m in seedMatches)
            {
                if (!string.IsNullOrEmpty(m.Trigger) && !_dict.ContainsKey(m.Trigger))
                    _dict[m.Trigger] = m;
            }
            await SaveDictAsync();
        }

        Snackbar.Add(LocalizationService.GetString("NewFile") + ": " + newName, Severity.Success);
        UpdateView();
        StateHasChanged();
    }

    private List<Match> GetTemplateMatches(string templateName, string sourceFile)
    {
        var blank = LocalizationService.GetString("TemplateBlank");
        var work = LocalizationService.GetString("TemplateWork");
        var personal = LocalizationService.GetString("TemplatePersonal");
        var code = LocalizationService.GetString("TemplateCode");
        var emoji = LocalizationService.GetString("TemplateEmoji");

        if (templateName == work)
        {
            return new()
            {
                new() { Trigger = ":sig", Replace = "Best regards,\nYour Name", SourceFile = sourceFile, Vars = new() },
                new() { Trigger = ":meeting", Replace = "Meeting notes:\n\nDate: \nAttendees: \nAgenda: ", SourceFile = sourceFile, Vars = new() },
            };
        }
        if (templateName == personal)
        {
            return new()
            {
                new() { Trigger = ":addr", Replace = "123 Main St, City, Country", SourceFile = sourceFile, Vars = new() },
                new() { Trigger = ":phone", Replace = "+1-555-0100", SourceFile = sourceFile, Vars = new() },
            };
        }
        if (templateName == code)
        {
            return new()
            {
                new() { Trigger = ":for", Replace = "for (int i = 0; i < count; i++)\n{\n    \n}", SourceFile = sourceFile, Vars = new() },
                new() { Trigger = ":try", Replace = "try\n{\n    \n}\ncatch (Exception ex)\n{\n    \n}", SourceFile = sourceFile, Vars = new() },
            };
        }
        if (templateName == emoji)
        {
            return new()
            {
                new() { Trigger = ":happy", Replace = "😊", SourceFile = sourceFile, Vars = new() },
                new() { Trigger = ":sad", Replace = "😢", SourceFile = sourceFile, Vars = new() },
                new() { Trigger = ":heart", Replace = "❤️", SourceFile = sourceFile, Vars = new() },
            };
        }
        return new();
    }

    private async Task OpenRenameDialog()
    {
        var currentName = FileName == "__uncategorized__" ? null : FileName;
        if (currentName == null) return;

        var parameters = new DialogParameters
        {
            { "ShowTemplate", false },
            { "InitialValue", currentName },
            { "SubmitLabel", LocalizationService.GetString("Rename") },
        };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall };
        var dialog = MudDialogService.Show<FileNameDialog>(LocalizationService.GetString("RenameFile"), parameters, options);
        var result = await dialog.Result;
        if (result.Canceled || result.Data is not (string newName, _)) return;

        if (string.IsNullOrWhiteSpace(newName)) return;

        if (!newName.EndsWith(".yml") && !newName.EndsWith(".yaml"))
        {
            Snackbar.Add(LocalizationService.GetString("InvalidFileName"), Severity.Error);
            return;
        }

        var existing = _dict.Values.Select(m => m.SourceFile).Where(s => !string.IsNullOrEmpty(s) && s != currentName).ToHashSet();
        if (existing.Contains(newName))
        {
            Snackbar.Add(LocalizationService.GetString("FileAlreadyExists"), Severity.Error);
            return;
        }

        foreach (var kv in _dict)
        {
            if (kv.Value.SourceFile == currentName)
                kv.Value.SourceFile = newName;
        }

        await SaveDictAsync();
        NavigationManager.NavigateTo($"/files/{newName}");
    }

    private async Task ConfirmDeleteFile()
    {
        var currentName = FileName == "__uncategorized__" ? null : FileName;
        if (currentName == null) return;

        var confirm = await DialogService.DisplayConfirmAsync(
            LocalizationService.GetString("DeleteFile"),
            LocalizationService.GetString("DeleteFileWarning"),
            LocalizationService.GetString("Delete"),
            LocalizationService.GetString("Cancel"));

        if (!confirm) return;

        var keysToRemove = _dict.Where(kv => kv.Value.SourceFile == currentName).Select(kv => kv.Key).ToList();
        foreach (var key in keysToRemove)
            _dict.Remove(key);

        await SaveDictAsync();
        NavigationManager.NavigateTo("/files");
    }

    private void EnterYamlEditMode()
    {
        var currentName = FileName == "__uncategorized__" ? null : FileName;
        var matches = _dict.Where(kv =>
            (kv.Value.SourceFile == currentName) ||
            (kv.Value.SourceFile == null && FileName == "__uncategorized__"))
            .Select(kv => kv.Value).ToList();
        _yamlText = YamlWorkspace.SerializeFileMatches(matches);
        _yamlEditMode = true;
    }

    private void CancelYamlEdit()
    {
        _yamlEditMode = false;
        _yamlText = "";
    }

    private async Task SaveYamlEdit()
    {
        try
        {
            var group = YamlWorkspace.ParseYaml(_yamlText, FileName == "__uncategorized__" ? null : FileName);
            if (group.Matches == null || group.Matches.Count == 0)
            {
                Snackbar.Add(LocalizationService.GetString("EmptyFile"), Severity.Warning);
                return;
            }

            var currentName = FileName == "__uncategorized__" ? null : FileName;
            var keysToRemove = _dict.Where(kv => kv.Value.SourceFile == currentName).Select(kv => kv.Key).ToList();
            foreach (var key in keysToRemove)
                _dict.Remove(key);

            foreach (var match in group.Matches)
            {
                match.SourceFile = currentName;
                if (match.Triggers is not null && match.Triggers.Count > 0)
                {
                    foreach (var t in match.Triggers)
                    {
                        var clone = new Match(match) { Trigger = t, SourceFile = currentName };
                        _dict[t] = clone;
                    }
                }
                else if (!string.IsNullOrEmpty(match.Trigger))
                {
                    _dict[match.Trigger] = match;
                }
            }

            await SaveDictAsync();
            _yamlEditMode = false;
            _yamlText = "";
            UpdateView();
            StateHasChanged();
            Snackbar.Add(LocalizationService.GetString("Saved"), Severity.Success);
        }
        catch (Exception e)
        {
            Snackbar.Add(e.Message, Severity.Error);
        }
    }

    private async Task SaveDictAsync()
    {
        try
        {
            var str = JsonSerializer.Serialize(_dict);
            await File.WriteAllTextAsync(AppSettings.DictPath, str);

            var config = SyncManager.GetConfig();
            if (config.Method != SyncMethod.None && !string.IsNullOrEmpty(config.SyncUri))
            {
                _ = SyncManager.PushAsync(_dict, _globalVars);
            }
        }
        catch (Exception e)
        {
            Snackbar.Add(e.Message, Severity.Error);
        }
    }

    public void Dispose() { }
}
