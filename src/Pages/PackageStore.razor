@page "/packages"
@using EspansoGo.Models
@using EspansoGo.Services
@using CommunityToolkit.Mvvm.Messaging
@inject HubClient HubClient
@inject ISnackbar Snackbar
@inject ILocalizationService localizationService
@implements IDisposable

<MudTabs @bind-ActivePanelIndex="_activeTab" Elevation="2" Rounded="true">
    <MudTabPanel Text="@localizationService.GetString("Browse")">
        <MudTextField @bind-Value="_searchQuery"
                      Label="@localizationService.GetString("SearchPackages")"
                      Variant="Variant.Outlined"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@MudBlazor.Icons.Material.Filled.Search"
                      class="mb-4 mt-4"
                      Immediate="true" DebounceInterval="300" />

        @if (_loading)
        {
            <MudStack Spacing="3" Class="pa-4">
                @for (int i = 0; i < 4; i++)
                {
                    <MudSkeleton Height="120px" Elevation="1" />
                }
            </MudStack>
        }
        else if (_packages.Count == 0)
        {
            <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-8">
                <MudIcon Icon="@Icons.Material.Filled.Inventory2" Size="Size.Large" Color="Color.Default" />
                <MudText Typo="Typo.body2" Color="Color.Default" Align="Align.Center">@localizationService.GetString("NoPackagesFound")</MudText>
            </MudStack>
        }
        else
        {
            <MudGrid Spacing="3">
                @foreach (var pkg in _filteredPackages)
                {
                    <MudItem xs="12" sm="6" md="4">
                        <MudCard Class="mb-3">
                            <MudCardContent>
                                <MudText Typo="Typo.h6">@pkg.Title</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Default" class="mb-2">by @pkg.Author</MudText>
                                <MudText Typo="Typo.body2" class="mb-2" Style="min-height: 40px; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                                    @pkg.Description
                                </MudText>
                                @if (!string.IsNullOrEmpty(pkg.Tags))
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Default">
                                        @pkg.Tags
                                    </MudText>
                                }
                            </MudCardContent>
                            <MudCardActions>
                                @if (_installedNames.Contains(pkg.Name))
                                {
                                    <MudButton Color="Color.Error" Variant="Variant.Text" OnClick="() => UninstallPackage(pkg)"
                                               Disabled="@(_busyPackage != null)">
                                        @if (_busyPackage == pkg.Name) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="ms-2" /> }
                                        else { @localizationService.GetString("Uninstall") }
                                    </MudButton>
                                }
                                else
                                {
                                    <MudButton Color="Color.Primary" Variant="Variant.Filled"
                                               OnClick="() => InstallPackage(pkg)"
                                               Disabled="@(_busyPackage != null)">
                                        @if (_busyPackage == pkg.Name) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="ms-2" /> }
                                        else { @localizationService.GetString("Install") }
                                    </MudButton>
                                }
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        }

        <MudStack Row="true" Spacing="2" class="mt-4" AlignItems="AlignItems.Center">
            <MudButton Variant="Variant.Outlined" OnClick="RefreshIndex" Disabled="@_loading">
                @localizationService.GetString("RefreshIndex")
            </MudButton>
        </MudStack>
    </MudTabPanel>

    <MudTabPanel Text="@localizationService.GetString("Installed")">
        @if (_installedPackages.Count == 0)
        {
            <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-8">
                <MudIcon Icon="@Icons.Material.Filled.DownloadDone" Size="Size.Large" Color="Color.Default" />
                <MudText Typo="Typo.body2" Color="Color.Default" Align="Align.Center">@localizationService.GetString("NoInstalledPackages")</MudText>
            </MudStack>
        }
        else
        {
            @foreach (var pkg in _installedPackages)
            {
                <MudCard Class="mb-3 pa-4">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" Align="Align.Center">
                        <div>
                            <MudText Typo="Typo.h6">@pkg.Name</MudText>
                            <MudText Typo="Typo.body2">@string.Format(localizationService.GetString("MatchFiles"), pkg.MatchFiles.Count)</MudText>
                        </div>
                        <MudButton Color="Color.Error" Variant="Variant.Text" OnClick="() => UninstallInstalledPackage(pkg)"
                                   Disabled="@(_busyPackage != null)">
                            @if (_busyPackage == pkg.Name) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="ms-2" /> }
                            else { @localizationService.GetString("Uninstall") }
                        </MudButton>
                    </MudStack>
                </MudCard>
            }
        }
    </MudTabPanel>
</MudTabs>

@code {
    private List<HubPackageInfo> _packages = new();
    private List<HubPackageInfo> _filteredPackages = new();
    private HashSet<string> _installedNames = new();
    private List<InstalledPackage> _installedPackages = new();
    private string _searchQuery = "";
    private bool _loading = true;
    private string _busyPackage = null;
    private int _activeTab = 0;

    protected override async Task OnInitializedAsync()
    {
        localizationService.OnLanguageChanged += OnLanguageChanged;
        await LoadDataAsync();
    }

    private void OnLanguageChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task LoadDataAsync()
    {
        _loading = true;
        try
        {
            var index = await HubClient.GetPackageIndexAsync();
            _packages = index.Packages;
            _installedNames = HubClient.GetInstalledPackages().Select(p => p.Name).ToHashSet();
            _installedPackages = HubClient.GetInstalledPackages();
            ApplyFilter();
        }
        catch (Exception ex)
        {
            Snackbar.Add(string.Format(localizationService.GetString("FailedToLoadPackages"), ex.Message), Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void ApplyFilter()
    {
        if (string.IsNullOrWhiteSpace(_searchQuery))
        {
            _filteredPackages = _packages;
        }
        else
        {
            var query = _searchQuery.ToLowerInvariant();
            _filteredPackages = _packages.Where(p =>
                (p.Name?.ToLowerInvariant().Contains(query) == true) ||
                (p.Title?.ToLowerInvariant().Contains(query) == true) ||
                (p.Description?.ToLowerInvariant().Contains(query) == true) ||
                (p.Tags?.ToLowerInvariant().Contains(query) == true)
            ).ToList();
        }
    }

    private async Task RefreshIndex()
    {
        _loading = true;
        try
        {
            var index = await HubClient.GetPackageIndexAsync(forceRefresh: true);
            _packages = index.Packages;
            ApplyFilter();
            Snackbar.Add(string.Format(localizationService.GetString("LoadedPackages"), _packages.Count), Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(string.Format(localizationService.GetString("RefreshFailed"), ex.Message), Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task InstallPackage(HubPackageInfo pkg)
    {
        _busyPackage = pkg.Name;
        try
        {
            Snackbar.Add(string.Format(localizationService.GetString("InstallingPackage"), pkg.Name), Severity.Info);
            var installed = await HubClient.InstallPackageAsync(pkg);
            if (installed != null)
            {
                _installedNames.Add(pkg.Name);
                _installedPackages = HubClient.GetInstalledPackages();
                Snackbar.Add(string.Format(localizationService.GetString("InstalledPackage"), pkg.Name, installed.MatchFiles.Count), Severity.Success);
                WeakReferenceMessenger.Default.Send(new AcServiceMessage(("Reload", null)));
                _activeTab = 1;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(string.Format(localizationService.GetString("InstallFailed"), ex.Message), Severity.Error);
        }
        finally
        {
            _busyPackage = null;
        }
    }

    private async Task UninstallPackage(HubPackageInfo pkg) => await DoUninstall(pkg.Name);

    private async Task UninstallInstalledPackage(InstalledPackage pkg) => await DoUninstall(pkg.Name);

    private async Task DoUninstall(string pkgName)
    {
        _busyPackage = pkgName;
        try
        {
            await Task.Run(() => HubClient.UninstallPackage(pkgName));
            _installedNames.Remove(pkgName);
            _installedPackages = HubClient.GetInstalledPackages();
            Snackbar.Add(string.Format(localizationService.GetString("UninstalledPackage"), pkgName), Severity.Success);
            WeakReferenceMessenger.Default.Send(new AcServiceMessage(("Reload", null)));
        }
        catch (Exception ex)
        {
            Snackbar.Add(string.Format(localizationService.GetString("UninstallFailed"), ex.Message), Severity.Error);
        }
        finally
        {
            _busyPackage = null;
        }
    }

    public void Dispose()
    {
        localizationService.OnLanguageChanged -= OnLanguageChanged;
    }
}
